# DIG Browser OS identity: app name, AppUserModelID, ProgIDs, User Data path.
#
# Renames the Windows install identity from Chromium to DIG Browser so the
# window/taskbar name, Task Manager entry, ProgIDs, and the per-user data dir
# (%LOCALAPPDATA%\DIG Browser) all read DIG Browser, not Chromium.
--- a/chrome/install_static/chromium_install_modes.h
+++ b/chrome/install_static/chromium_install_modes.h
@@ -34,14 +34,14 @@
         .logo_suffix = L"",  // No logo suffix for the primary install mode.
         .app_guid =
             L"",  // Empty app_guid since no integration with Google Update.
-        .base_app_name = L"Chromium",              // A distinct base_app_name.
-        .base_app_id = L"Chromium",                // A distinct base_app_id.
-        .browser_prog_id_prefix = L"ChromiumHTM",  // Browser ProgID prefix.
+        .base_app_name = L"DIG Browser",           // A distinct base_app_name.
+        .base_app_id = L"DIGBrowser",              // A distinct base_app_id.
+        .browser_prog_id_prefix = L"DIGBrowserHTM",  // Browser ProgID prefix.
         .browser_prog_id_description =
-            L"Chromium HTML Document",         // Browser ProgID description.
-        .pdf_prog_id_prefix = L"ChromiumPDF",  // PDF ProgID prefix.
+            L"DIG Browser HTML Document",      // Browser ProgID description.
+        .pdf_prog_id_prefix = L"DIGBrowserPDF",  // PDF ProgID prefix.
         .pdf_prog_id_description =
-            L"Chromium PDF Document",  // PDF ProgID description.
+            L"DIG Browser PDF Document",  // PDF ProgID description.
         .active_setup_guid =
             L"{7D2B3E1D-D096-4594-9D8F-A6667F12E0AC}",  // Active Setup
                                                         // GUID.
--- a/chrome/install_static/chromium_install_modes.cc
+++ b/chrome/install_static/chromium_install_modes.cc
@@ -14,10 +14,10 @@
 
 const wchar_t kCompanyPathName[] = L"";
 
-const wchar_t kProductPathName[] = L"Chromium";
+const wchar_t kProductPathName[] = L"DIG Browser";
 
 const size_t kProductPathNameLength = _countof(kProductPathName) - 1;
 
-const char kSafeBrowsingName[] = "chromium";
+const char kSafeBrowsingName[] = "dig_browser";
 
 }  // namespace install_static
