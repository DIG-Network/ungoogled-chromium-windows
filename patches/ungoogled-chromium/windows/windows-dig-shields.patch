+// Copyright 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// DIG Browser: the toolbar DIG-identity button (the Brave-Shields analogue).
+// A classic shield silhouette with a "D" knocked out of its face, so the mark
+// reads as "DIG protection / identity" at the toolbar size as a single
+// monochrome silhouette tinted by the active toolbar theme color. Drawn on the
+// standard 20dp toolbar canvas (matches navigate_home_chrome_refresh.icon and
+// dig_wallet.icon).
+//
+// FILL_RULE_NONZERO with opposing winding: the shield body is wound clockwise
+// (filled); the "D" glyph is wound counter-clockwise so it punches through as a
+// hole, then the D's inner counter (the bowl) is wound clockwise again so it
+// fills back — giving a crisp letter-D read in negative space.
+
+CANVAS_DIMENSIONS, 20,
+FILL_RULE_NONZERO,
+
+// --- Shield body: a heraldic shield from the top edge down to a rounded point.
+// Top-center (10,2) -> right shoulder -> straight down -> taper to the point at
+// the bottom (10,18) -> up the left -> back to top. Clockwise. ---
+MOVE_TO, 10, 2,
+CUBIC_TO, 12.6, 3.1, 14.8, 3.6, 16.5, 3.6,
+V_LINE_TO, 9.5,
+CUBIC_TO, 16.5, 13.4, 13.9, 16.3, 10, 18,
+CUBIC_TO, 6.1, 16.3, 3.5, 13.4, 3.5, 9.5,
+V_LINE_TO, 3.6,
+CUBIC_TO, 5.2, 3.6, 7.4, 3.1, 10, 2,
+CLOSE,
+
+// --- "D" outer outline knocked out of the shield face, centered ~ (9.6,9.6).
+// Stem at the left, bowl bulging right. Counter-clockwise so it subtracts. ---
+MOVE_TO, 7.4, 6.2,
+H_LINE_TO, 10.0,
+CUBIC_TO, 12.3, 6.2, 13.8, 7.7, 13.8, 9.8,
+CUBIC_TO, 13.8, 11.9, 12.3, 13.4, 10.0, 13.4,
+H_LINE_TO, 7.4,
+V_LINE_TO, 6.2,
+CLOSE,
+
+// --- "D" inner counter (the bowl), wound clockwise so it fills back, leaving
+// the letter D as a ring of negative space. ---
+MOVE_TO, 9.0, 7.9,
+V_LINE_TO, 11.7,
+H_LINE_TO, 10.0,
+CUBIC_TO, 11.2, 11.7, 12.0, 10.9, 12.0, 9.8,
+CUBIC_TO, 12.0, 8.7, 11.2, 7.9, 10.0, 7.9,
+CLOSE
