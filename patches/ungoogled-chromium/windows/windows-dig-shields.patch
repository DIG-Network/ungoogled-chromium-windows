+// DIG Browser: the signature DIG-identity toolbar button — the Brave-Shields
+// analogue. It carries the DIG shield mark and, when pressed, opens the DIG
+// identity panel (chia://shields) anchored just beneath the button, the way
+// Brave anchors its Shields panel under the lion. The panel unifies, under one
+// DIG identity: the dig:// "verified / served-locally" status of the active
+// page and the browser's privacy posture (ad/tracker/fingerprint controls, DNT,
+// HTTPS-Only, encrypted DNS).
+//
+// The panel itself is a branded chia://shields page served from the binary by
+// the in-process dig handler (dig_url_loader_factory.cc) — the same crash-safe
+// embedded-HTML pattern as chia://about / chia://welcome. The button reads the
+// ACTIVE tab's dig status at press time and passes it to the panel as query
+// parameters so the panel reflects the page it was opened over.
+class DigShieldsButton : public ToolbarButton {
+  METADATA_HEADER(DigShieldsButton, ToolbarButton)
+
+ public:
+  explicit DigShieldsButton(BrowserWindowInterface* browser_window_interface);
+  DigShieldsButton(const DigShieldsButton&) = delete;
+  DigShieldsButton& operator=(const DigShieldsButton&) = delete;
+  ~DigShieldsButton() override;
+
+ private:
+  // Opens the DIG identity panel (chia://shields) as a small popup anchored
+  // beneath this button, carrying the active tab's dig status as query params.
+  void OpenShieldsPanel(const ui::Event& event);
+
+  // Builds chia://shields?... with the active tab's dig:// identity status
+  // (scheme, verified, source = local/remote, host/store id).
+  std::string BuildPanelUrl() const;
+
+  raw_ptr<BrowserWindowInterface> browser_window_interface_;
+  raw_ptr<Profile> profile_;
+};
+
+}  // namespace dig
+
+#endif  // CHROME_BROWSER_UI_VIEWS_TOOLBAR_DIG_SHIELDS_BUTTON_H_
