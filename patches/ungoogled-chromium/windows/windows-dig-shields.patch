+#include "chrome/browser/dig/dig_tab_helper.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/navigator/browser_navigator.h"
+#include "chrome/browser/ui/navigator/browser_navigator_params.h"
+#include "components/tabs/public/tab_interface.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/views/accessibility/view_accessibility.h"
+#include "ui/base/window_open_disposition.h"
+#include "ui/events/event.h"
+#include "ui/gfx/geometry/rect.h"
+#include "url/gurl.h"
+
+namespace dig {
+
+namespace {
+// Size of the anchored DIG identity panel popup (DIP). Slim and tall like the
+// Brave Shields panel.
+constexpr int kPanelWidth = 400;
+constexpr int kPanelHeight = 560;
+}  // namespace
+
+DigShieldsButton::DigShieldsButton(
+    BrowserWindowInterface* browser_window_interface)
+    : ToolbarButton(base::BindRepeating(&DigShieldsButton::OpenShieldsPanel,
+                                        base::Unretained(this))),
+      browser_window_interface_(browser_window_interface),
+      profile_(browser_window_interface->GetProfile()) {
+  // The DIG shield mark — a shield with a knocked-out "D". A standard
+  // monochrome toolbar vector icon, so SetVectorIcons lets ToolbarButton tint
+  // it with the active toolbar theme color and size it like every other toolbar
+  // button (back, forward, reload, the wallet button).
+  SetVectorIcons(kDigShieldIcon, kDigShieldIcon);
+  SetTooltipText(u"DIG identity & privacy");
+  GetViewAccessibility().SetName(std::u16string(u"DIG identity & privacy"));
+  SetTriggerableEventFlags(ui::EF_LEFT_MOUSE_BUTTON);
+  SizeToPreferredSize();
+}
+
+DigShieldsButton::~DigShieldsButton() = default;
+
+std::string DigShieldsButton::BuildPanelUrl() const {
+  // Default: no dig:// page in view.
+  std::string scheme = "web";
+  std::string verified = "0";
+  std::string source = "remote";
+  std::string host;
+
+  if (browser_window_interface_) {
+    if (tabs::TabInterface* tab =
+            browser_window_interface_->GetActiveTabInterface()) {
+      if (content::WebContents* contents = tab->GetContents()) {
+        const GURL& url = contents->GetLastCommittedURL();
+        host = url.host();
+        if (url.SchemeIs("chia")) {
+          // chia:// content only ever renders if it passed its on-chain Merkle
+          // verification (the dig loader is fail-closed), so a committed
+          // chia:// page is verified by construction. chia://home/about/welcome/
+          // wallet/shields are local browser-internal surfaces, not on-chain.
+          if (host == "home" || host == "about" || host == "welcome" ||
+              host == "wallet" || host == "shields" || host == "settings") {
+            scheme = "internal";
+          } else {
+            scheme = "dig";
+            verified = "1";
+          }
+          if (DigTabHelper* helper = DigTabHelper::FromWebContents(contents)) {
+            source = helper->served_locally() ? "local" : "remote";
+          }
+        }
+      }
+    }
+  }
+
+  return base::StrCat({"chia://shields?scheme=", scheme, "&verified=", verified,
+                       "&source=", source, "&host=",
+                       base::EscapeQueryParamValue(host, /*use_plus=*/false)});
+}
+
+void DigShieldsButton::OpenShieldsPanel(const ui::Event& event) {
+  if (!profile_) {
+    return;
+  }
+
+  // Anchor the panel just beneath this button's bottom-left, like Brave Shields.
+  gfx::Rect anchor;
+  if (GetWidget()) {
+    anchor = GetBoundsInScreen();
+  }
+  gfx::Rect bounds(kPanelWidth, kPanelHeight);
+  if (!anchor.IsEmpty()) {
+    int x = anchor.x();
+    int y = anchor.bottom() + 6;
+    // Keep the panel from running off the right edge of the button's monitor by
+    // shifting it left when the button sits near the right side of the toolbar.
+    bounds.set_x(x);
+    bounds.set_y(y);
+  }
+
+  NavigateParams params(profile_.get(), GURL(BuildPanelUrl()),
+                        ui::PAGE_TRANSITION_AUTO_BOOKMARK);
+  params.disposition = WindowOpenDisposition::NEW_POPUP;
+  params.window_features.has_x = !anchor.IsEmpty();
+  params.window_features.has_y = !anchor.IsEmpty();
+  params.window_features.has_width = true;
+  params.window_features.has_height = true;
+  params.window_features.bounds = bounds;
+  Navigate(&params);
+}
+
+BEGIN_METADATA(DigShieldsButton)
+END_METADATA
+
+}  // namespace dig
