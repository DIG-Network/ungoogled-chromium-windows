+module dig.mojom;
+
+// Frame-scoped interface: the injected `window.chia` provider (renderer, main
+// world) calls this to reach the in-process DIG wallet in the BROWSER process —
+// directly, with no loopback HTTP, so it is never subject to the page's CSP.
+//
+// The renderer does NOT send an origin. The browser handler supplies the calling
+// frame's UNSPOOFABLE committed origin (RenderFrameHost::GetLastCommittedOrigin)
+// to the wallet's per-origin approval gate, then calls the wallet FFI on a
+// blocking thread. `response_json` is the wallet's JSON envelope:
+// `{"status":<u16>,"body":<json>}` (HTTP-equivalent status + body).
+interface DigWalletRpc {
+  Request(string request_json) => (string response_json);
+};
