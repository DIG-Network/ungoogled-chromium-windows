+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/renderer/dig/dig_wallet_bridge.h"
+
+#include <memory>
+#include <tuple>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "content/public/renderer/render_frame.h"
+#include "gin/converter.h"
+#include "third_party/blink/public/platform/browser_interface_broker_proxy.h"
+#include "third_party/blink/public/platform/scheduler/web_agent_group_scheduler.h"
+#include "third_party/blink/public/web/web_local_frame.h"
+#include "v8/include/v8-context.h"
+#include "v8/include/v8-external.h"
+#include "v8/include/v8-function.h"
+#include "v8/include/v8-function-callback.h"
+#include "v8/include/v8-isolate.h"
+#include "v8/include/v8-microtask-queue.h"
+#include "v8/include/v8-object.h"
+#include "v8/include/v8-template.h"
+
+namespace dig {
+
+DigWalletBridge::DigWalletBridge(content::RenderFrame* render_frame)
+    : render_frame_(render_frame) {}
+
+DigWalletBridge::~DigWalletBridge() = default;
+
+void DigWalletBridge::InstallOnContext(v8::Isolate* isolate,
+                                       v8::Local<v8::Context> context) {
+  v8::HandleScope handle_scope(isolate);
+  v8::Context::Scope context_scope(context);
+
+  // A plain function whose External data is this frame-scoped bridge. NO cppgc
+  // wrappable is created in the page heap — only an ordinary v8::Object holding
+  // an ordinary bound function. `this` outlives the context (the owning
+  // RenderFrameObserver shares the frame's lifetime), so the External stays
+  // valid for every call made while the context is alive.
+  v8::Local<v8::External> data =
+      v8::External::New(isolate, this, v8::kExternalPointerTypeTagDefault);
+  v8::Local<v8::FunctionTemplate> request_tmpl = v8::FunctionTemplate::New(
+      isolate, &DigWalletBridge::RequestCallback, data);
+  v8::Local<v8::Function> request_fn;
+  if (!request_tmpl->GetFunction(context).ToLocal(&request_fn)) {
+    return;
+  }
+
+  v8::Local<v8::Object> bridge_obj = v8::Object::New(isolate);
+  if (bridge_obj
+          ->Set(context, gin::StringToV8(isolate, "request"), request_fn)
+          .IsNothing()) {
+    return;
+  }
+
+  std::ignore = context->Global()->Set(
+      context, gin::StringToV8(isolate, "__digWalletRpc"), bridge_obj);
+}
+
+// static
+void DigWalletBridge::RequestCallback(
+    const v8::FunctionCallbackInfo<v8::Value>& info) {
+  v8::Isolate* isolate = info.GetIsolate();
+  auto* bridge = static_cast<DigWalletBridge*>(
+      info.Data().As<v8::External>()->Value(
+          v8::kExternalPointerTypeTagDefault));
+  if (!bridge) {
+    return;
+  }
+  std::string json;
+  v8::Local<v8::Function> callback;
+  if (info.Length() < 2 || !gin::ConvertFromV8(isolate, info[0], &json) ||
+      !info[1]->IsFunction()) {
+    isolate->ThrowError(gin::StringToV8(
+        isolate,
+        "__digWalletRpc.request(jsonString, callback) requires a string and a "
+        "function"));
+    return;
+  }
+  callback = info[1].As<v8::Function>();
+  bridge->Request(isolate, json, callback);
+}
+
+bool DigWalletBridge::EnsureRemote() {
+  if (remote_.is_bound()) {
+    return true;
+  }
+  if (!render_frame_) {
+    return false;
+  }
+  render_frame_->GetBrowserInterfaceBroker().GetInterface(
+      remote_.BindNewPipeAndPassReceiver());
+  return remote_.is_bound();
+}
+
+void DigWalletBridge::Request(v8::Isolate* isolate,
+                              const std::string& request_json,
+                              v8::Local<v8::Function> callback) {
+  auto global_cb = std::make_unique<v8::Global<v8::Function>>(isolate, callback);
+  if (!EnsureRemote()) {
+    // No frame/pipe — answer empty so the provider surfaces "not reachable".
+    OnReply(std::move(global_cb), std::string());
+    return;
+  }
+  remote_->Request(request_json,
+                   base::BindOnce(&DigWalletBridge::OnReply,
+                                  weak_factory_.GetWeakPtr(),
+                                  std::move(global_cb)));
+}
+
+void DigWalletBridge::OnReply(
+    std::unique_ptr<v8::Global<v8::Function>> callback,
+    const std::string& response) {
+  if (!render_frame_) {
+    return;
+  }
+  blink::WebLocalFrame* frame = render_frame_->GetWebFrame();
+  if (!frame) {
+    return;
+  }
+  v8::Isolate* isolate = frame->GetAgentGroupScheduler()->Isolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = frame->MainWorldScriptContext();
+  if (context.IsEmpty()) {
+    return;
+  }
+  v8::Context::Scope context_scope(context);
+  v8::MicrotasksScope microtasks_scope(context,
+                                       v8::MicrotasksScope::kRunMicrotasks);
+  v8::Local<v8::Function> fn = callback->Get(isolate);
+  if (fn.IsEmpty()) {
+    return;
+  }
+  v8::Local<v8::Value> arg = gin::StringToV8(isolate, response);
+  std::ignore = fn->Call(isolate, context, context->Global(), 1, &arg);
+}
+
+}  // namespace dig
