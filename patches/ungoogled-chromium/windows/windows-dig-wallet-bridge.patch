+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_RENDERER_DIG_DIG_WALLET_BRIDGE_H_
+#define CHROME_RENDERER_DIG_DIG_WALLET_BRIDGE_H_
+
+#include <memory>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/weak_ptr.h"
+#include "chrome/common/dig/dig_wallet_rpc.mojom.h"
+#include "mojo/public/cpp/bindings/remote.h"
+#include "v8/include/v8-forward.h"
+#include "v8/include/v8-persistent-handle.h"
+
+namespace content {
+class RenderFrame;
+}
+
+namespace dig {
+
+// Renderer-side native bridge for the injected `window.chia` provider.
+//
+// IMPORTANT (incident 2026-06-27): this is deliberately NOT a
+// `gin::Wrappable` / cppgc-managed object. A per-page cppgc `gin::Wrappable`
+// allocated into an arbitrary web page's MAIN WORLD crashed the renderer on
+// every navigation. Instead, this bridge is a plain C++ object OWNED BY THE
+// `ChromeRenderFrameObserver` (one per frame; its lifetime == the frame's).
+// The main-world `window.__digWalletRpc` it installs is just a plain
+// `v8::Object` carrying a single bound C++ function (`request`); the function's
+// `v8::External` data points back at this frame-scoped bridge. There is no
+// cppgc-managed wrappable in the page heap.
+//
+// `request(json, cb)` forwards the request over a frame-scoped Mojo pipe to the
+// browser process (DigWalletRpcHandler → in-process wallet FFI) and invokes
+// `cb` with the JSON envelope string when the reply arrives. NO network/fetch,
+// so it is never subject to the page's CSP. The provider JS wraps this in a
+// Promise. The browser side stamps the calling frame's unspoofable committed
+// origin onto the request for the wallet's per-origin approval gate.
+class DigWalletBridge {
+ public:
+  explicit DigWalletBridge(content::RenderFrame* render_frame);
+  DigWalletBridge(const DigWalletBridge&) = delete;
+  DigWalletBridge& operator=(const DigWalletBridge&) = delete;
+  ~DigWalletBridge();
+
+  // Install `window.__digWalletRpc` on `context`'s global. Called from
+  // ChromeRenderFrameObserver::DidClearWindowObject for each web-scheme frame
+  // (re-runs whenever the window object is recreated). Safe to call repeatedly.
+  void InstallOnContext(v8::Isolate* isolate, v8::Local<v8::Context> context);
+
+ private:
+  // v8 function callback for `__digWalletRpc.request(jsonString, callback)`.
+  // Recovers the bridge from the function's External data and dispatches.
+  static void RequestCallback(const v8::FunctionCallbackInfo<v8::Value>& info);
+
+  // Dispatch one request: forward over Mojo, resolve `callback` with the
+  // response envelope (empty string if the wallet is unreachable).
+  void Request(v8::Isolate* isolate,
+               const std::string& request_json,
+               v8::Local<v8::Function> callback);
+
+  void OnReply(std::unique_ptr<v8::Global<v8::Function>> callback,
+               const std::string& response);
+
+  // Bind `remote_` to the browser handler via the frame's interface broker
+  // (lazy, on first use). Returns false if the frame is gone.
+  bool EnsureRemote();
+
+  const raw_ptr<content::RenderFrame> render_frame_;
+  mojo::Remote<mojom::DigWalletRpc> remote_;
+  base::WeakPtrFactory<DigWalletBridge> weak_factory_{this};
+};
+
+}  // namespace dig
+
+#endif  // CHROME_RENDERER_DIG_DIG_WALLET_BRIDGE_H_
