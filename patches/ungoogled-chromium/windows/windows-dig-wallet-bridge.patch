+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/dig/dig_wallet_rpc_handler.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/task/thread_pool.h"
+#include "chrome/browser/dig/dig_native_runtime.h"
+#include "content/public/browser/render_frame_host.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+#include "url/origin.h"
+
+namespace dig {
+
+// static
+void DigWalletRpcHandler::Bind(
+    content::RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<mojom::DigWalletRpc> receiver) {
+  mojo::MakeSelfOwnedReceiver(
+      std::make_unique<DigWalletRpcHandler>(render_frame_host),
+      std::move(receiver));
+}
+
+DigWalletRpcHandler::DigWalletRpcHandler(
+    content::RenderFrameHost* render_frame_host)
+    : render_frame_host_(render_frame_host) {}
+
+DigWalletRpcHandler::~DigWalletRpcHandler() = default;
+
+void DigWalletRpcHandler::Request(const std::string& request_json,
+                                  RequestCallback callback) {
+  // The calling frame's committed origin is supplied by the browser process —
+  // the renderer cannot spoof it. The wallet's per-origin approval gate keys on
+  // it. Read it synchronously here (UI thread); the frame is not touched again.
+  const std::string origin =
+      render_frame_host_->GetLastCommittedOrigin().Serialize();
+
+  // CallWalletRpc BLOCKS (drives the in-process wallet runtime), so run it on a
+  // MayBlock thread-pool task and reply on this sequence — mirrors how the
+  // dig:// URL loader calls CallDigRpc. Only the origin string + the reply
+  // callback are captured, so this is safe regardless of the frame's lifetime.
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_BLOCKING},
+      base::BindOnce(&dig::CallWalletRpc, origin, request_json),
+      std::move(callback));
+}
+
+}  // namespace dig
