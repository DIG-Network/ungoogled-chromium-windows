+namespace dig {
+
+// Browser-process implementation of the frame-scoped DigWalletRpc interface
+// (window.chia → in-process wallet, no network). One self-owned instance per
+// receiver, pinned to the requesting frame so its committed origin is read
+// unspoofably on the browser side and handed to the wallet's per-origin gate.
+class DigWalletRpcHandler : public mojom::DigWalletRpc {
+ public:
+  // Binds a new self-owned handler for `render_frame_host`'s receiver. Wired in
+  // chrome_browser_interface_binders.cc (PopulateChromeFrameBinders).
+  static void Bind(content::RenderFrameHost* render_frame_host,
+                   mojo::PendingReceiver<mojom::DigWalletRpc> receiver);
+
+  explicit DigWalletRpcHandler(content::RenderFrameHost* render_frame_host);
+  DigWalletRpcHandler(const DigWalletRpcHandler&) = delete;
+  DigWalletRpcHandler& operator=(const DigWalletRpcHandler&) = delete;
+  ~DigWalletRpcHandler() override;
+
+  // mojom::DigWalletRpc:
+  void Request(const std::string& request_json,
+               RequestCallback callback) override;
+
+ private:
+  const raw_ptr<content::RenderFrameHost> render_frame_host_;
+};
+
+}  // namespace dig
+
+#endif  // CHROME_BROWSER_DIG_DIG_WALLET_RPC_HANDLER_H_
