# DIG Browser: DuckDuckGo is the default search engine (privacy-first).
#
# Non-DIG web searches from the omnibox and the DIG Home new-tab page go to
# DuckDuckGo out of the box (no Google). GetPrepopulatedFallbackSearch (the
# default-search fallback used when no engine is otherwise chosen) returns the
# DuckDuckGo prepopulated engine instead of Google.
#
# Generated by diffing the build tree against pristine 149.0.7827.155.
--- a/components/search_engines/template_url_prepopulate_data.cc
+++ b/components/search_engines/template_url_prepopulate_data.cc
@@ -275,8 +275,12 @@
     PrefService& prefs,
     const std::vector<const PrepopulatedEngine*>&
         regional_prepopulated_engines) {
+  // DIG Browser: DuckDuckGo is the default search engine (privacy-first, no
+  // Google). Web searches from the omnibox / NTP go to DDG out of the box. This
+  // is the fallback used when no engine is otherwise chosen; if a region's list
+  // lacks DDG, `use_first_as_fallback` still yields a working default.
   return FindPrepopulatedEngineInternal(prefs, regional_prepopulated_engines,
-                                        google.id,
+                                        duckduckgo.id,
                                         /*use_first_as_fallback=*/true);
 }
 
