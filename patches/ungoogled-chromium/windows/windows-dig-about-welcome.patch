--- a/chrome/browser/ui/startup/startup_tab_provider_unittest.cc
+++ b/chrome/browser/ui/startup/startup_tab_provider_unittest.cc
@@ -57,6 +57,36 @@
   EXPECT_TRUE(output.empty());
 }
 
+// DIG Browser: on first run with no distribution-specified tabs, the branded
+// DIG welcome tour (chia://welcome) is shown.
+TEST(StartupTabProviderTest, GetFirstRunTabsForState_DigWelcomeOnFirstRun) {
+  StartupTabs output = StartupTabProviderImpl::GetFirstRunTabsForState(
+      /*is_first_run=*/true, StartupTabs());
+
+  ASSERT_EQ(1U, output.size());
+  EXPECT_EQ(GURL("chia://welcome"), output[0].url);
+}
+
+// DIG Browser: an explicit distribution initial_preferences config still wins
+// on first run — the welcome tour is NOT injected when tabs were specified.
+TEST(StartupTabProviderTest, GetFirstRunTabsForState_DistributionTabsWin) {
+  StartupTabs input({StartupTab(GURL("https://dig.net/"))});
+
+  StartupTabs output = StartupTabProviderImpl::GetFirstRunTabsForState(
+      /*is_first_run=*/true, input);
+
+  ASSERT_EQ(1U, output.size());
+  EXPECT_EQ(GURL("https://dig.net/"), output[0].url);
+}
+
+// DIG Browser: the welcome tour is first-run only — not on later launches.
+TEST(StartupTabProviderTest, GetFirstRunTabsForState_NotFirstRun) {
+  StartupTabs output = StartupTabProviderImpl::GetFirstRunTabsForState(
+      /*is_first_run=*/false, StartupTabs());
+
+  EXPECT_TRUE(output.empty());
+}
