# DIG Browser first-run welcome tour (chia://welcome).
#
# On first launch, DIG Browser opens its own branded welcome experience — a few
# slides covering what DIG Browser is (in-network dig:// + a native Chia wallet +
# privacy-by-default) and a set-as-default prompt — instead of a bare new tab.
# This is the Brave-style first-run tour, in the DIG palette (violet -> magenta,
# Space Grotesk). The page itself (chia://welcome) is an embedded resource served
# by the in-process dig handler (dig_url_loader_factory.cc); the welcome HTML is
# generated by build.py from dig/welcome/dig_welcome.html into dig_welcome_html.inc
# (no patch needed for the generated .inc), exactly like dig://home.
#
# The first-run decision is factored into a pure, testable static helper
# (GetFirstRunTabsForState): on first run with no distribution-specified tabs it
# returns chia://welcome; an explicit initial_preferences config still wins.
--- a/chrome/browser/ui/startup/startup_tab_provider.h
+++ b/chrome/browser/ui/startup/startup_tab_provider.h
@@ -95,6 +95,15 @@
       bool is_first_run,
       const std::vector<GURL>& first_run_tabs);
 
+  // DIG Browser: decides the first-run tabs. `initial_prefs_tabs` is the result
+  // of GetInitialPrefsTabsForState (the distribution's initial_preferences). On
+  // first run with no distribution-specified tabs, this returns the branded DIG
+  // welcome tour (chia://welcome); otherwise it passes the input through
+  // unchanged. Pure policy (no system state), exposed for testing.
+  static StartupTabs GetFirstRunTabsForState(
+      bool is_first_run,
+      const StartupTabs& initial_prefs_tabs);
+
   // Determines which tabs should be shown as a result of the presence/absence
   // of a Reset Trigger on this profile.
   static StartupTabs GetResetTriggerTabsForState(bool profile_has_trigger);
--- a/chrome/browser/ui/startup/startup_tab_provider.cc
+++ b/chrome/browser/ui/startup/startup_tab_provider.cc
@@ -109,10 +109,26 @@
   if (!browser_creator) {
     return StartupTabs();
   }
-  StartupTabs tabs = GetInitialPrefsTabsForState(
-      first_run::IsChromeFirstRun(), browser_creator->first_run_tabs_);
+  const bool is_first_run = first_run::IsChromeFirstRun();
+  StartupTabs initial_prefs_tabs =
+      GetInitialPrefsTabsForState(is_first_run, browser_creator->first_run_tabs_);
   browser_creator->first_run_tabs_.clear();
-  return tabs;
+  return GetFirstRunTabsForState(is_first_run, initial_prefs_tabs);
+}
+
+// static
+StartupTabs StartupTabProviderImpl::GetFirstRunTabsForState(
+    bool is_first_run,
+    const StartupTabs& initial_prefs_tabs) {
+  // DIG Browser: on first run, open the branded DIG welcome tour (chia://welcome
+  // — what DIG Browser is, dig:// + the native wallet + privacy, and a
+  // set-as-default prompt), served from the embedded resource by the in-process
+  // dig handler. Only when the distribution didn't already specify first-run
+  // tabs, so an explicit initial_preferences config still wins.
+  if (is_first_run && initial_prefs_tabs.empty()) {
+    return StartupTabs({StartupTab(GURL("chia://welcome"))});
+  }
+  return initial_prefs_tabs;
 }
 
