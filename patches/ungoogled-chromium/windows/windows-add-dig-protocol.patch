+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+//
+// Native client-side read-crypto for the DIG Network content contract. This is
+// a byte-for-byte C++ port of the canonical Rust implementation in
+// `digstore-core` (crypto.rs + merkle.rs + urn.rs) and the cross-system
+// contract documented in the ecosystem SYSTEM.md. It implements exactly what
+// the reference `dig-chrome-extension` does via the `dig_client` WASM, but with
+// BoringSSL (already a //net dependency) instead of a bundled WASM module:
+//
+//   * retrieval_key = SHA-256(canonical rootless URN), lowercase hex
+//       canonical rootless URN = "urn:dig:chia:<store_id>[/<resource_key>]"
+//       (empty resource_key resolves to "index.html"); SYSTEM.md "Retrieval key"
+//   * Merkle inclusion proof verification against the trusted root
+//       leaf = SHA-256(served_ciphertext) (untagged D5 leaf)
+//       node = SHA-256(NODE_TAG || left || right), NODE_TAG="digstore:node:v1"
+//       proof wire (big-endian Chia streamable codec):
+//         leaf[32] || path_count:u32 || (sibling[32] || is_left:u8)* || root[32]
+//       SYSTEM.md "Merkle inclusion proof"
+//   * AES-256 content key = HKDF-SHA256(
+//         ikm  = canonical rootless URN bytes,
+//         salt = SHA-256("digstore-hkdf-salt-v1" [|| secret_salt]),
+//         info = "digstore-aes-256-gcm-key-v1")
+//       SYSTEM.md "AES-256-GCM-SIV + HKDF-SHA256"
+//   * AES-256-GCM-SIV decrypt under a FIXED 12-byte zero nonce, ct = data||tag.
+//
+// All verification/decryption is FAIL-CLOSED: any tamper / wrong key / decoy
+// yields an error and no plaintext is ever produced.
+
+#ifndef NET_URL_REQUEST_DIG_CRYPTO_H_
+#define NET_URL_REQUEST_DIG_CRYPTO_H_
+
+#include <cstdint>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "net/base/net_export.h"
+
+namespace net::dig {
+
+// Canonical rootless URN string: "urn:dig:chia:<store_id>[/<resource_key>]".
+// `resource_key` empty -> "index.html" (paper 8.5 default view). This is the
+// form whose SHA-256 is the retrieval key and whose bytes seed the AES key.
+NET_EXPORT std::string CanonicalRootlessUrn(const std::string& chain,
+                                            const std::string& store_id_hex,
+                                            const std::string& resource_key);
+
+// retrieval_key = SHA-256(canonical_rootless_urn), lowercase hex (64 chars).
+NET_EXPORT std::string RetrievalKeyHex(const std::string& chain,
+                                       const std::string& store_id_hex,
+                                       const std::string& resource_key);
+
+// Derive the 32-byte AES-256 content key. `secret_salt_hex` is the optional
+// 32-byte private-store secret salt as hex (std::nullopt for public stores).
+// Returns false on malformed salt hex.
+NET_EXPORT bool DeriveContentKey(const std::string& canonical_rootless_urn,
+                                 const std::optional<std::string>& secret_salt_hex,
+                                 uint8_t out_key[32]);
+
+// Verify that `ciphertext` is included under `trusted_root_hex` via the
+// base64 merkle `proof_b64`. Returns true only if the proof's leaf equals
+// SHA-256(ciphertext), the path folds (with NODE_TAG) to the proof root, and
+// (when `trusted_root_hex` is a 64-char hex root) that root matches the proof
+// root. A `trusted_root_hex` of "latest" means the URN pinned no root, so the
+// proof root is trusted as served (the GCM-SIV tag remains the hard gate).
+NET_EXPORT bool VerifyInclusion(const std::vector<uint8_t>& ciphertext,
+                                const std::string& proof_b64,
+                                const std::string& trusted_root_hex);
+
+// AES-256-GCM-SIV decrypt one chunk (ct = data||16-byte tag) under `key`.
+// Returns false on tag failure (tamper / wrong key / decoy) — fail-closed.
+NET_EXPORT bool DecryptChunk(const uint8_t key[32],
+                             const std::vector<uint8_t>& ciphertext,
+                             std::vector<uint8_t>* out_plaintext);
+
+// Decrypt the reassembled ciphertext split by per-chunk ciphertext lengths
+// `chunk_lens` (empty => treat the whole blob as one chunk). The sum of
+// `chunk_lens` MUST equal ciphertext.size(). Returns false on any mismatch or
+// tag failure. This mirrors the extension's decryptChunks() exactly.
+NET_EXPORT bool DecryptResource(const uint8_t key[32],
+                                const std::vector<uint8_t>& ciphertext,
+                                const std::vector<uint32_t>& chunk_lens,
+                                std::vector<uint8_t>* out_plaintext);
+
+}  // namespace net::dig
+
+#endif  // NET_URL_REQUEST_DIG_CRYPTO_H_
