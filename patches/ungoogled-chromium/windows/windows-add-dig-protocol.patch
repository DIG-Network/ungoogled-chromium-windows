+#include <string_view>
+#include <vector>
+
+#include "base/strings/string_split.h"
+#include "base/strings/string_util.h"
+
+namespace net::dig {
+
+namespace {
+
+bool IsHex64(const std::string& s) {
+  if (s.size() != 64) {
+    return false;
+  }
+  for (char c : s) {
+    if (!base::IsHexDigit(c)) {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool IsAllHex(const std::string& s) {
+  if (s.empty()) {
+    return false;
+  }
+  for (char c : s) {
+    if (!base::IsHexDigit(c)) {
+      return false;
+    }
+  }
+  return true;
+}
+
+// Extract the value of a `salt=<hex>` query parameter from `query` (the part
+// after '?'), or return std::nullopt. Mirrors the extension's ?salt=<hex> read.
+std::optional<std::string> ExtractSalt(const std::string& query) {
+  for (const auto& kv : base::SplitStringPiece(
+           query, "&", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+    auto eq = kv.find('=');
+    if (eq == std::string_view::npos) {
+      continue;
+    }
+    if (kv.substr(0, eq) == "salt") {
+      std::string val(kv.substr(eq + 1));
+      if (IsAllHex(val)) {
+        return base::ToLowerASCII(val);
+      }
+    }
+  }
+  return std::nullopt;
+}
+
+}  // namespace
+
+ParsedUrn ParseDigUrn(const std::string& input) {
+  ParsedUrn out;
+  std::string s = input;
+
+  // Strip the dig:// scheme prefix and any leading slashes (path-style callers).
+  if (base::StartsWith(s, "dig://", base::CompareCase::INSENSITIVE_ASCII)) {
+    s = s.substr(6);
+  } else if (base::StartsWith(s, "dig:", base::CompareCase::INSENSITIVE_ASCII)) {
+    s = s.substr(4);
+  }
+  while (!s.empty() && s.front() == '/') {
+    s.erase(s.begin());
+  }
+  // Strip the urn:dig: prefix if present.
+  if (base::StartsWith(s, "urn:dig:", base::CompareCase::INSENSITIVE_ASCII)) {
+    s = s.substr(8);
+  }
+
+  // Extract an optional ?salt=<hex> private-store param, then drop any query.
+  size_t q = s.find('?');
+  if (q != std::string::npos) {
+    out.salt = ExtractSalt(s.substr(q + 1));
+    s = s.substr(0, q);
+  }
+
+  // Split off the resource path at the FIRST '/'.
+  std::string head = s;
+  std::string resource_key;
+  size_t slash = s.find('/');
+  if (slash != std::string::npos) {
+    head = s.substr(0, slash);
+    resource_key = s.substr(slash + 1);
+  }
+
+  // head = [<chain>:]<storeID>[:<rootHash>]
+  std::vector<std::string> parts = base::SplitString(
+      head, ":", base::TRIM_WHITESPACE, base::SPLIT_WANT_ALL);
+
+  std::string chain = "chia";
+  std::string store_id;
+  std::optional<std::string> root_hash;
+
+  if (parts.size() == 1) {
+    // <storeID>
+    store_id = parts[0];
+  } else if (parts.size() == 2) {
+    // Either <chain>:<storeID> or <storeID>:<rootHash>.
+    if (IsHex64(parts[0]) && IsHex64(parts[1])) {
+      store_id = parts[0];
+      root_hash = base::ToLowerASCII(parts[1]);
+    } else {
+      chain = parts[0];
+      store_id = parts[1];
+    }
+  } else if (parts.size() == 3) {
+    // <chain>:<storeID>:<rootHash>
+    chain = parts[0];
+    store_id = parts[1];
+    root_hash = base::ToLowerASCII(parts[2]);
+  } else {
+    return out;  // too many ':' segments
+  }
+
+  if (!IsHex64(store_id)) {
+    return out;
+  }
+  if (root_hash.has_value() && !IsHex64(*root_hash)) {
+    return out;
+  }
+
+  out.chain = base::ToLowerASCII(chain);
+  out.store_id = base::ToLowerASCII(store_id);
+  out.root_hash = root_hash;
+  out.resource_key = resource_key;
+  out.valid = true;
+  return out;
+}
+
+ParsedUrn ParseDigHostUrl(const std::string& host,
+                          const std::string& path,
+                          const std::string& query) {
+  ParsedUrn out;
+  out.chain = "chia";
+
+  // host = <store_id> | <root_hash>.<store_id>
+  std::vector<std::string> labels = base::SplitString(
+      host, ".", base::TRIM_WHITESPACE, base::SPLIT_WANT_ALL);
+  std::string store_id;
+  std::optional<std::string> root_hash;
+  if (labels.size() == 1) {
+    store_id = labels[0];
+  } else if (labels.size() == 2) {
+    root_hash = base::ToLowerASCII(labels[0]);
+    store_id = labels[1];
+  } else {
+    return out;  // unexpected host shape
+  }
+
+  if (!IsHex64(store_id)) {
+    return out;
+  }
+  if (root_hash.has_value() && !IsHex64(*root_hash)) {
+    return out;
+  }
+
+  // path is GURL::path(), which already excludes the query. Strip the leading
+  // '/'; the remainder is the resource key ("" => default view, applied by the
+  // caller / crypto layer as index.html).
+  std::string resource_key = path;
+  while (!resource_key.empty() && resource_key.front() == '/') {
+    resource_key.erase(resource_key.begin());
+  }
+
+  if (!query.empty()) {
+    out.salt = ExtractSalt(query);
+  }
+  out.store_id = base::ToLowerASCII(store_id);
+  out.root_hash = root_hash;
+  out.resource_key = resource_key;
+  out.valid = true;
+  return out;
+}
