+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+//
+// dig:// URN parsing. Mirrors the shared parser in the reference
+// `dig-chrome-extension` (dig-urn.mjs) and the canonical Rust parser in
+// `digstore-core` (urn.rs). Accepts both the full URN form
+//   urn:dig:<chain>:<storeID>[:<rootHash>][/<resourceKey>][?salt=<hex>]
+// and the dig:// shorthand
+//   dig://<chain>:<storeID>[:<rootHash>][/<resourceKey>]
+//   dig://<storeID>[:<rootHash>][/<resourceKey>]   (chain defaults to "chia")
+// See SYSTEM.md "Digstore URN scheme".
+
+#ifndef NET_URL_REQUEST_DIG_URN_H_
+#define NET_URL_REQUEST_DIG_URN_H_
+
+#include <optional>
+#include <string>
+
+#include "net/base/net_export.h"
+
+namespace net::dig {
+
+struct NET_EXPORT ParsedUrn {
+  std::string chain;             // e.g. "chia"
+  std::string store_id;          // 64-char lowercase hex
+  std::optional<std::string> root_hash;     // 64-char lowercase hex, or none
+  std::string resource_key;      // "" means default view (index.html)
+  std::optional<std::string> salt;          // private-store secret salt (hex)
+  bool valid = false;
+};
+
+// Parse a dig:// URL or a urn:dig: string. Returns a ParsedUrn with valid=false
+// on any malformed input.
+NET_EXPORT ParsedUrn ParseDigUrn(const std::string& input);
+
+// Parse the canonical host-bearing form that the browser navigates to and that
+// relative subresources resolve against:
+//   host = <store_id>              -> rootless (root defaults to "latest")
+//   host = <root_hash>.<store_id>  -> rooted
+// (both labels 64-char hex), path = "/<resource_key>" ("" => default index.html),
+// query may carry "salt=<hex>". chain is assumed "chia". Returns valid=false on
+// a malformed host. `host`/`path`/`query` come straight from GURL::host()/path()/
+// query().
+NET_EXPORT ParsedUrn ParseDigHostUrl(const std::string& host,
+                                     const std::string& path,
+                                     const std::string& query);
+
+}  // namespace net::dig
+
+#endif  // NET_URL_REQUEST_DIG_URN_H_
