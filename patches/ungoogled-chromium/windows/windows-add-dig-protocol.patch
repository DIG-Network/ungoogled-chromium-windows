+// DIG Browser: dig: is registered as an opaque-non-special scheme (see
+// url_util.cc) so a dig:// URL carrying a colon-laden urn:dig: payload parses
+// as a valid opaque-path URL (like steam:) instead of trying to read a
+// host:port out of the urn. These cases guard the native dig:// navigation
+// entry point.
+TEST_F(GURLTest, DigSchemeIsValidOpaquePathUrl) {
+  const std::string kStore =
+      "1426d9064bb59353e2ad3845c1d250af1f75476a6d4d85f2c4d6b90696359907";
+  const std::string kRoot =
+      "cc77916250e587e9d39d9fca59afdaf1bce89aa26c4d56249b2c14406dda8e4e";
+  const std::string kUrn =
+      "urn:dig:chia:" + kStore + ":" + kRoot + "/index.html";
+
+  // Because `dig` is registered in SchemeRegistry::opaque_non_special_schemes
+  // (see url_util.cc), dig: URLs are canonicalized via the legacy PathURL path:
+  // the entire colon-laden urn payload is carried verbatim in the URL's path,
+  // and the URL parses as valid instead of trying to read a host:port out of
+  // the urn. (PathURL parsing does not set the has_opaque_path flag — the
+  // payload is simply the path — so this proof asserts on the surviving
+  // payload, which is what the dig:// loader re-parses.)
+
+  // Form 1: dig://urn:dig:chia:<store>:<root>/index.html
+  GURL form1("dig://" + kUrn);
+  EXPECT_TRUE(form1.is_valid()) << form1.possibly_invalid_spec();
+  EXPECT_EQ("dig", form1.scheme());
+  // The colon-laden urn payload survives in the spec / path.
+  EXPECT_NE(std::string::npos, form1.possibly_invalid_spec().find(kStore));
+  EXPECT_NE(std::string::npos, form1.possibly_invalid_spec().find(kRoot));
+  EXPECT_NE(std::string::npos,
+            form1.possibly_invalid_spec().find("index.html"));
+  EXPECT_NE(std::string::npos, form1.GetContent().find(kStore));
+
+  // Form 2: dig:urn:dig:chia:<store>:<root>/index.html (no slashes)
+  GURL form2("dig:" + kUrn);
+  EXPECT_TRUE(form2.is_valid()) << form2.possibly_invalid_spec();
+  EXPECT_EQ("dig", form2.scheme());
+  EXPECT_NE(std::string::npos, form2.possibly_invalid_spec().find(kStore));
+  EXPECT_NE(std::string::npos, form2.GetContent().find(kStore));
+
+  // Form 3: the full urn:dig: form is the user-facing canonical address. GURL
+  // parses it under the urn: scheme; the omnibox/URL-fixer layer rewrites it to
+  // the dig: shorthand above before navigation. Here we only assert it is a
+  // well-formed urn: URL whose payload is preserved.
+  GURL form3(kUrn);
+  EXPECT_TRUE(form3.is_valid()) << form3.possibly_invalid_spec();
+  EXPECT_EQ("urn", form3.scheme());
+  EXPECT_NE(std::string::npos, form3.possibly_invalid_spec().find(kStore));
+
+  // dig: must NOT be parsed as an empty document (it carries a payload).
+  EXPECT_FALSE(form1.is_empty());
+  EXPECT_FALSE(form2.is_empty());
+}
