+++ b/net/url_request/dig_crypto.cc
@@ -0,0 +1,247 @@
+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "net/url_request/dig_crypto.h"
+
+#include <cstring>
+
+#include "base/base64.h"
+#include "base/containers/span.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_util.h"
+#include "third_party/boringssl/src/include/openssl/aead.h"
+#include "third_party/boringssl/src/include/openssl/digest.h"
+#include "third_party/boringssl/src/include/openssl/hkdf.h"
+#include "third_party/boringssl/src/include/openssl/sha.h"
+
+namespace net::dig {
+
+namespace {
+
+// Cross-system constants — MUST stay byte-identical to digstore-core
+// (crypto.rs / merkle.rs) and the SYSTEM.md "Shared contracts" table.
+constexpr char kHkdfSaltDomain[] = "digstore-hkdf-salt-v1";
+constexpr char kHkdfInfo[] = "digstore-aes-256-gcm-key-v1";
+constexpr char kNodeTag[] = "digstore:node:v1";
+constexpr char kDefaultResourceKey[] = "index.html";
+
+constexpr size_t kKeyLen = 32;
+constexpr size_t kNonceLen = 12;
+constexpr size_t kTagLen = 16;  // AES-GCM-SIV authentication tag.
+
+void Sha256(base::span<const uint8_t> data, uint8_t out[SHA256_DIGEST_LENGTH]) {
+  SHA256_CTX ctx;
+  SHA256_Init(&ctx);
+  if (!data.empty()) {
+    SHA256_Update(&ctx, data.data(), data.size());
+  }
+  SHA256_Final(out, &ctx);
+}
+
+std::string ToLowerHex(base::span<const uint8_t> bytes) {
+  return base::ToLowerASCII(base::HexEncode(bytes));
+}
+
+}  // namespace
+
+std::string CanonicalRootlessUrn(const std::string& chain,
+                                 const std::string& store_id_hex,
+                                 const std::string& resource_key) {
+  std::string chain_str = chain.empty() ? "chia" : chain;
+  std::string rk = resource_key.empty() ? kDefaultResourceKey : resource_key;
+  return "urn:dig:" + chain_str + ":" + base::ToLowerASCII(store_id_hex) + "/" +
+         rk;
+}
+
+std::string RetrievalKeyHex(const std::string& chain,
+                            const std::string& store_id_hex,
+                            const std::string& resource_key) {
+  const std::string urn = CanonicalRootlessUrn(chain, store_id_hex, resource_key);
+  uint8_t digest[SHA256_DIGEST_LENGTH];
+  Sha256(base::as_byte_span(urn), digest);
+  return ToLowerHex(digest);
+}
+
+bool DeriveContentKey(const std::string& canonical_rootless_urn,
+                      const std::optional<std::string>& secret_salt_hex,
+                      uint8_t out_key[kKeyLen]) {
+  // salt = SHA-256("digstore-hkdf-salt-v1" [|| secret_salt]).
+  SHA256_CTX ctx;
+  SHA256_Init(&ctx);
+  SHA256_Update(&ctx, kHkdfSaltDomain, std::strlen(kHkdfSaltDomain));
+  if (secret_salt_hex.has_value() && !secret_salt_hex->empty()) {
+    std::vector<uint8_t> secret;
+    if (!base::HexStringToBytes(*secret_salt_hex, &secret)) {
+      return false;  // malformed private-store salt
+    }
+    if (!secret.empty()) {
+      SHA256_Update(&ctx, secret.data(), secret.size());
+    }
+  }
+  uint8_t salt[SHA256_DIGEST_LENGTH];
+  SHA256_Final(salt, &ctx);
+
+  // okm = HKDF-SHA256(ikm = canonical_urn bytes, salt, info).
+  return HKDF(out_key, kKeyLen, EVP_sha256(),
+              reinterpret_cast<const uint8_t*>(canonical_rootless_urn.data()),
+              canonical_rootless_urn.size(), salt, sizeof(salt),
+              reinterpret_cast<const uint8_t*>(kHkdfInfo),
+              std::strlen(kHkdfInfo)) == 1;
+}
+
+bool VerifyInclusion(const std::vector<uint8_t>& ciphertext,
+                     const std::string& proof_b64,
+                     const std::string& trusted_root_hex) {
+  // Decode the base64 proof. Wire layout (big-endian Chia streamable codec):
+  //   leaf[32] || path_count:u32 || (sibling[32] || is_left:u8)* || root[32]
+  std::string proof_bytes;
+  if (!base::Base64Decode(proof_b64, &proof_bytes)) {
+    return false;
+  }
+  const auto* p = reinterpret_cast<const uint8_t*>(proof_bytes.data());
+  size_t remaining = proof_bytes.size();
+
+  if (remaining < 32u + 4u) {
+    return false;
+  }
+  // leaf
+  uint8_t leaf[32];
+  std::memcpy(leaf, p, 32);
+  p += 32;
+  remaining -= 32;
+  // path_count (u32 big-endian)
+  uint32_t path_count = (static_cast<uint32_t>(p[0]) << 24) |
+                        (static_cast<uint32_t>(p[1]) << 16) |
+                        (static_cast<uint32_t>(p[2]) << 8) |
+                        (static_cast<uint32_t>(p[3]));
+  p += 4;
+  remaining -= 4;
+
+  // Each step is 33 bytes (32 hash + 1 flag); then a trailing 32-byte root.
+  if (path_count > (proof_bytes.size() / 33u) + 1u) {
+    return false;  // implausible count, avoid overflow
+  }
+  if (remaining < static_cast<size_t>(path_count) * 33u + 32u) {
+    return false;
+  }
+
+  // The proof leaf MUST equal SHA-256(served ciphertext) (D5 leaf). This binds
+  // the served bytes to the committed merkle leaf.
+  uint8_t computed_leaf[SHA256_DIGEST_LENGTH];
+  Sha256(ciphertext, computed_leaf);
+  if (std::memcmp(computed_leaf, leaf, 32) != 0) {
+    return false;
+  }
+
+  // Fold the path up to the root using the NODE domain tag.
+  uint8_t acc[32];
+  std::memcpy(acc, leaf, 32);
+  for (uint32_t i = 0; i < path_count; ++i) {
+    const uint8_t* sibling = p;
+    uint8_t is_left = p[32];
+    p += 33;
+    remaining -= 33;
+    if (is_left != 0 && is_left != 1) {
+      return false;
+    }
+    SHA256_CTX ctx;
+    SHA256_Init(&ctx);
+    SHA256_Update(&ctx, kNodeTag, std::strlen(kNodeTag));
+    if (is_left == 1) {
+      // sibling on the LEFT: node = SHA256(NODE_TAG || sibling || acc)
+      SHA256_Update(&ctx, sibling, 32);
+      SHA256_Update(&ctx, acc, 32);
+    } else {
+      // sibling on the RIGHT: node = SHA256(NODE_TAG || acc || sibling)
+      SHA256_Update(&ctx, acc, 32);
+      SHA256_Update(&ctx, sibling, 32);
+    }
+    SHA256_Final(acc, &ctx);
+  }
+
+  // Trailing root from the proof.
+  const uint8_t* proof_root = p;
+
+  // The folded accumulator must equal the proof's stated root.
+  if (std::memcmp(acc, proof_root, 32) != 0) {
+    return false;
+  }
+
+  // If the URN pinned a concrete root, the proof root MUST match it. When the
+  // URN supplied no root the client passes "latest"; the proof root is then the
+  // served generation root (the GCM-SIV tag is the remaining content gate).
+  if (trusted_root_hex != "latest" && trusted_root_hex.size() == 64) {
+    std::vector<uint8_t> trusted;
+    if (!base::HexStringToBytes(trusted_root_hex, &trusted) ||
+        trusted.size() != 32) {
+      return false;
+    }
+    if (std::memcmp(trusted.data(), proof_root, 32) != 0) {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool DecryptChunk(const uint8_t key[kKeyLen],
+                  const std::vector<uint8_t>& ciphertext,
+                  std::vector<uint8_t>* out_plaintext) {
+  if (ciphertext.size() < kTagLen) {
+    return false;
+  }
+  bssl::ScopedEVP_AEAD_CTX ctx;
+  if (!EVP_AEAD_CTX_init(ctx.get(), EVP_aead_aes_256_gcm_siv(), key, kKeyLen,
+                         kTagLen, nullptr)) {
+    return false;
+  }
+  static const uint8_t kFixedNonce[kNonceLen] = {0};
+  out_plaintext->resize(ciphertext.size());  // plaintext <= ciphertext
+  size_t out_len = 0;
+  int ok = EVP_AEAD_CTX_open(ctx.get(), out_plaintext->data(), &out_len,
+                             out_plaintext->size(), kFixedNonce, kNonceLen,
+                             ciphertext.data(), ciphertext.size(),
+                             /*ad=*/nullptr, /*ad_len=*/0);
+  if (ok != 1) {
+    out_plaintext->clear();
+    return false;  // tag failure: tamper / wrong key / decoy — fail closed
+  }
+  out_plaintext->resize(out_len);
+  return true;
+}
+
+bool DecryptResource(const uint8_t key[kKeyLen],
+                     const std::vector<uint8_t>& ciphertext,
+                     const std::vector<uint32_t>& chunk_lens,
+                     std::vector<uint8_t>* out_plaintext) {
+  out_plaintext->clear();
+
+  // Empty chunk_lens => whole blob is one GCM-SIV ciphertext.
+  if (chunk_lens.empty()) {
+    return DecryptChunk(key, ciphertext, out_plaintext);
+  }
+
+  uint64_t sum = 0;
+  for (uint32_t len : chunk_lens) {
+    sum += len;
+  }
+  if (sum != ciphertext.size()) {
+    return false;  // framing mismatch — hard integrity check
+  }
+
+  size_t pos = 0;
+  for (uint32_t len : chunk_lens) {
+    std::vector<uint8_t> chunk(ciphertext.begin() + pos,
+                               ciphertext.begin() + pos + len);
+    std::vector<uint8_t> part;
+    if (!DecryptChunk(key, chunk, &part)) {
+      out_plaintext->clear();
+      return false;
+    }
+    out_plaintext->insert(out_plaintext->end(), part.begin(), part.end());
+    pos += len;
+  }
+  return true;
+}
