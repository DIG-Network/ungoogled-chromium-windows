+// ---------------------------------------------------------------------------
+// DigProtocolJob: async URLRequestJob that drives the rpc.dig.net read path.
+//
+// It owns a nested URLRequest (POST to the RPC endpoint), reassembles the
+// streamed ciphertext + inclusion proof, verifies + decrypts client-side via
+// net::dig::*, then serves the resulting bytes through the standard
+// URLRequestJob read interface.
+// ---------------------------------------------------------------------------
+class DigProtocolJob : public URLRequestJob, public URLRequest::Delegate {
+ public:
+  explicit DigProtocolJob(URLRequest* request)
+      : URLRequestJob(request) {}
+
+  DigProtocolJob(const DigProtocolJob&) = delete;
+  DigProtocolJob& operator=(const DigProtocolJob&) = delete;
+
+  ~DigProtocolJob() override = default;
+
+  // URLRequestJob:
+  void Start() override {
+    parsed_ = dig::ParseDigUrn(request()->url().possibly_invalid_spec());
+    if (!parsed_.valid) {
+      FinishWithError("That dig:// address isn't a valid DIG URN.");
+      return;
+    }
+    chain_ = parsed_.chain.empty() ? "chia" : parsed_.chain;
+    resource_key_ =
+        parsed_.resource_key.empty() ? "index.html" : parsed_.resource_key;
+    root_ = parsed_.root_hash.value_or("latest");
+    retrieval_key_ =
+        dig::RetrievalKeyHex(chain_, parsed_.store_id, parsed_.resource_key);
+
+    StartRpcWindow(0);
+  }
+
+  void Kill() override {
+    weak_factory_.InvalidateWeakPtrs();
+    rpc_request_.reset();
+    URLRequestJob::Kill();
+  }
+
+  int ReadRawData(IOBuffer* buf, int buf_size) override {
+    if (read_offset_ >= static_cast<int64_t>(output_.size())) {
+      return 0;  // EOF
+    }
+    int64_t remaining = static_cast<int64_t>(output_.size()) - read_offset_;
+    int to_copy = static_cast<int>(std::min<int64_t>(remaining, buf_size));
+    std::memcpy(buf->data(), output_.data() + read_offset_, to_copy);
+    read_offset_ += to_copy;
+    return to_copy;
+  }
+
+  void GetResponseInfo(HttpResponseInfo* info) override {
+    std::string headers = base::StrCat(
+        {"HTTP/1.1 200 OK\r\nContent-Type: ", mime_type_,
+         "\r\nX-Dig-Verified: ", verified_ ? "true" : "false", "\r\n\r\n"});
+    info->headers = base::MakeRefCounted<HttpResponseHeaders>(
+        HttpUtil::AssembleRawHeaders(headers));
+  }
+
+  bool GetMimeType(std::string* mime_type) const override {
+    *mime_type = mime_type_;
+    return true;
+  }
+
+  // URLRequest::Delegate (for the nested RPC request):
+  void OnResponseStarted(URLRequest* request, int net_error) override {
+    if (net_error != OK) {
+      FinishWithError("Couldn't reach the DIG content network.");
+      return;
+    }
+    PumpRpcBody();
+  }
+
+  void OnReadCompleted(URLRequest* request, int bytes_read) override {
+    // Async completion of a Read(): record the bytes, then keep pumping.
+    if (bytes_read < 0) {
+      FinishWithError("Network error while reading DIG content.");
+      return;
+    }
+    if (bytes_read > 0) {
+      rpc_body_.append(rpc_read_buf_->data(), bytes_read);
+    }
+    if (bytes_read == 0) {
+      HandleRpcWindowComplete();  // this RPC window is fully read
+      return;
+    }
+    PumpRpcBody();
+  }
+
+ private:
+  void StartRpcWindow(int64_t offset) {
+    // Build the JSON-RPC 2.0 dig.getContent request body.
+    base::Value::Dict params;
+    params.Set("store_id", parsed_.store_id);
+    params.Set("root", root_);
+    params.Set("retrieval_key", retrieval_key_);
+    params.Set("offset", static_cast<double>(offset));
+    params.Set("length", kRpcChunk);
+
+    base::Value::Dict body;
+    body.Set("jsonrpc", "2.0");
+    body.Set("id", 1);
+    body.Set("method", "dig.getContent");
+    body.Set("params", std::move(params));
+
+    std::string json;
+    base::JSONWriter::Write(base::Value(std::move(body)), &json);
+
+    GURL endpoint(DigProtocolHandler::GetRpcEndpoint());
+    if (!endpoint.is_valid()) {
+      FinishWithError("DIG RPC endpoint is misconfigured.");
+      return;
+    }
+
+    net::NetworkTrafficAnnotationTag traffic_annotation =
+        net::DefineNetworkTrafficAnnotation("dig_protocol_get_content", R"(
+        semantics {
+          sender: "DIG Protocol Handler"
+          description:
+            "Fetches encrypted DIG Network content by retrieval key from the "
+            "configured DIG JSON-RPC read endpoint when the user navigates to "
+            "a dig:// URL. The response is verified (Merkle inclusion proof) "
+            "and decrypted entirely on the client; the server only ever sees "
+            "ciphertext keyed by a hash."
+          trigger: "User navigates to or loads a dig:// resource."
+          data: "A retrieval key (hash), store id, root, and byte range."
+          destination: WEBSITE
+        }
+        policy {
+          cookies_allowed: NO
+          setting: "Configurable via the DIG RPC endpoint setting."
+        })");
+
+    rpc_body_.clear();
+    rpc_request_ = request()->context()->CreateRequest(
+        endpoint, DEFAULT_PRIORITY, this, traffic_annotation);
+    rpc_request_->set_method("POST");
+    rpc_request_->SetExtraRequestHeaderByName("Content-Type", "application/json",
+                                              true);
+    rpc_request_->set_allow_credentials(false);
+
+    // Attach the JSON body as the POST upload. `rpc_upload_body_` outlives the
+    // request, so the bytes the reader points at stay valid for the upload.
+    rpc_upload_body_ = std::move(json);
+    auto reader = std::make_unique<UploadBytesElementReader>(
+        base::as_byte_span(rpc_upload_body_));
+    rpc_request_->set_upload(
+        ElementsUploadDataStream::CreateWithReader(std::move(reader)));
+    rpc_read_buf_ = base::MakeRefCounted<IOBufferWithSize>(kReadBufSize);
+    current_offset_ = offset;
+    rpc_request_->Start();
+  }
+
+  // Drain the nested RPC response synchronously where possible, looping over
+  // synchronous reads (so we never recurse per chunk). An ERR_IO_PENDING parks
+  // until OnReadCompleted() resumes the pump; a 0-length read ends the window.
+  void PumpRpcBody() {
+    for (;;) {
+      int bytes_read = rpc_request_->Read(rpc_read_buf_.get(), kReadBufSize);
+      if (bytes_read == ERR_IO_PENDING) {
+        return;  // OnReadCompleted will resume.
+      }
+      if (bytes_read < 0) {
+        FinishWithError("Network error while reading DIG content.");
+        return;
+      }
+      if (bytes_read == 0) {
+        HandleRpcWindowComplete();
+        return;
+      }
+      rpc_body_.append(rpc_read_buf_->data(), bytes_read);
+      // A single window's JSON should never exceed a base64-inflated 3 MiB
+      // chunk by much; bound it so a misbehaving endpoint can't exhaust memory.
+      if (rpc_body_.size() > static_cast<size_t>(kRpcChunk) * 2u + (1u << 20)) {
+        FinishWithError("DIG RPC response was unexpectedly large.");
+        return;
+      }
+    }
+  }
+
+  void HandleRpcWindowComplete() {
+    std::optional<base::Value> parsed = base::JSONReader::Read(rpc_body_);
+    if (!parsed || !parsed->is_dict()) {
+      FinishWithError("DIG RPC returned a malformed response.");
+      return;
+    }
+    const base::Value::Dict& root = parsed->GetDict();
+    if (const base::Value::Dict* err = root.FindDict("error")) {
+      const std::string* msg = err->FindString("message");
+      FinishWithError(msg ? *msg : "DIG RPC error.");
+      return;
+    }
+    const base::Value::Dict* result = root.FindDict("result");
+    if (!result) {
+      FinishWithError("DIG RPC returned no data.");
+      return;
+    }
+
+    // First window: allocate the output buffer and capture chunk_lens.
+    if (total_length_ < 0) {
+      std::optional<double> total = result->FindDouble("total_length");
+      if (!total || *total < 0 || *total > kMaxResourceBytes) {
+        FinishWithError("DIG resource is missing or too large.");
+        return;
+      }
+      total_length_ = static_cast<int64_t>(*total);
+      ciphertext_.assign(static_cast<size_t>(total_length_), 0);
+      if (const base::Value::List* lens = result->FindList("chunk_lens")) {
+        for (const base::Value& v : *lens) {
+          if (v.is_int()) {
+            chunk_lens_.push_back(static_cast<uint32_t>(v.GetInt()));
+          } else if (v.is_double()) {
+            chunk_lens_.push_back(static_cast<uint32_t>(v.GetDouble()));
+          }
+        }
+      }
+    }
+
+    // ciphertext (base64) lands at result.offset within the buffer.
+    const std::string* ct_b64 = result->FindString("ciphertext");
+    if (ct_b64 && !ct_b64->empty()) {
+      std::string decoded;
+      if (!base::Base64Decode(*ct_b64, &decoded)) {
+        FinishWithError("DIG RPC returned malformed ciphertext.");
+        return;
+      }
+      int64_t at = static_cast<int64_t>(result->FindDouble("offset").value_or(
+          static_cast<double>(current_offset_)));
+      int64_t writable =
+          std::max<int64_t>(0, std::min<int64_t>(
+              static_cast<int64_t>(decoded.size()), total_length_ - at));
+      if (at >= 0 && at + writable <= total_length_) {
+        std::memcpy(ciphertext_.data() + at, decoded.data(),
+                    static_cast<size_t>(writable));
+      }
+    }
+
+    // The inclusion proof is the base64 string for the whole resource.
+    if (const std::string* proof = result->FindString("inclusion_proof")) {
+      if (!proof->empty()) {
+        proof_b64_ = *proof;
+      }
+    }
+
+    bool complete = result->FindBool("complete").value_or(false);
+    std::optional<double> next = result->FindDouble("next_offset");
+    if (complete || !next.has_value()) {
+      FinishResolve();
+      return;
+    }
+    StartRpcWindow(static_cast<int64_t>(*next));
+  }
+
+  void FinishResolve() {
+    rpc_request_.reset();
+
+    // Verify the Merkle inclusion proof, then derive the key and decrypt.
+    // Verification is required: a failed proof or a decrypt tag failure means
+    // we serve NO content (fail closed).
+    verified_ = dig::VerifyInclusion(ciphertext_, proof_b64_, root_);
+    if (!verified_) {
+      FinishWithError(
+          "DIG content failed its on-chain integrity check (Merkle proof). "
+          "It may be tampered or a decoy.");
+      return;
+    }
+
+    const std::string canonical_urn =
+        dig::CanonicalRootlessUrn(chain_, parsed_.store_id, parsed_.resource_key);
+    uint8_t key[32];
+    if (!dig::DeriveContentKey(canonical_urn, parsed_.salt, key)) {
+      FinishWithError("DIG content key could not be derived.");
+      return;
+    }
+
+    std::vector<uint8_t> plaintext;
+    if (!dig::DecryptResource(key, ciphertext_, chunk_lens_, &plaintext)) {
+      FinishWithError(
+          "DIG content could not be decrypted (decoy, wrong key, or tamper).");
+      return;
+    }
+
+    output_ = std::move(plaintext);
+    mime_type_ = MimeForResourceKey(resource_key_);
+    set_expected_content_size(static_cast<int64_t>(output_.size()));
+    NotifyHeadersComplete();
+  }
+
+  void FinishWithError(const std::string& message) {
+    rpc_request_.reset();
+    std::string html = ErrorPageHtml(message);
+    output_.assign(html.begin(), html.end());
+    mime_type_ = "text/html";
+    verified_ = false;
+    set_expected_content_size(static_cast<int64_t>(output_.size()));
+    NotifyHeadersComplete();
+  }
+
+  dig::ParsedUrn parsed_;
+  std::string chain_;
+  std::string resource_key_;
+  std::string root_;
+  std::string retrieval_key_;
+
+  // Nested RPC request state.
+  std::unique_ptr<URLRequest> rpc_request_;
+  scoped_refptr<IOBufferWithSize> rpc_read_buf_;
+  std::string rpc_body_;
+  std::string rpc_upload_body_;  // outlives rpc_request_ (upload reader source)
+  int64_t current_offset_ = 0;
+
+  // Reassembly state.
+  int64_t total_length_ = -1;
+  std::vector<uint8_t> ciphertext_;
+  std::vector<uint32_t> chunk_lens_;
+  std::string proof_b64_;
+
+  // Output (decrypted plaintext, or branded error HTML).
+  std::vector<uint8_t> output_;
+  int64_t read_offset_ = 0;
+  std::string mime_type_ = "text/html";
+  bool verified_ = false;
+
+  base::WeakPtrFactory<DigProtocolJob> weak_factory_{this};
+};
+
+DigProtocolHandler::DigProtocolHandler() = default;
+
+std::unique_ptr<URLRequestJob> DigProtocolHandler::CreateJob(
+    URLRequest* request) const {
+  return std::make_unique<DigProtocolJob>(request);
+}
+
+bool DigProtocolHandler::IsSafeRedirectTarget(const GURL& location) const {
+  return true;
+}
+
+// static
+std::string DigProtocolHandler::GetRpcEndpoint() {
+  // DIG read path: by default the browser talks to the LOCAL dig-node sidecar
+  // (127.0.0.1:9778), not rpc.dig.net directly. dig-node is local-first — it
+  // serves cached .dig content with no network round-trip and proxies to
+  // rpc.dig.net only on a miss (caching the result) — so pointing the browser
+  // at it gives local-first dig:// for free, with the exact same dig.getContent
+  // contract and client-side verify/decrypt.
+  //
+  // Override with the DIG_RPC_ENDPOINT env var, e.g. a remote reference node or
+  // "https://rpc.dig.net/" for a node-less build that talks to the network
+  // directly. An empty/unset var falls back to the local node.
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::string endpoint = env->GetVar("DIG_RPC_ENDPOINT").value_or(std::string());
+  if (!endpoint.empty()) {
+    return endpoint;
+  }
+  return "http://127.0.0.1:9778/";
+}
