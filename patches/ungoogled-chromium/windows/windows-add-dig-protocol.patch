+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+//
+// Native dig:// protocol handler for the DIG Browser.
+//
+// Navigating to a dig:// URL resolves DIG Network content end-to-end, natively,
+// following the SAME contract as the reference dig-chrome-extension (see
+// SYSTEM.md "JSON-RPC 2.0 read methods" and the dig:// read path):
+//
+//   1. Parse the URN (full urn:dig:... form or dig:// shorthand).
+//   2. retrieval_key = SHA-256(canonical rootless URN).
+//   3. POST JSON-RPC 2.0 `dig.getContent` to the configured DIG RPC endpoint
+//      (default https://rpc.dig.net/), streaming 3 MiB windows until complete.
+//   4. Verify the Merkle inclusion proof against the trusted root.
+//   5. Derive the per-URN AES-256 key (HKDF) and decrypt AES-256-GCM-SIV.
+//   6. Render the verified + decrypted bytes with the extension-derived MIME.
+//
+// Verification/decryption are FAIL-CLOSED: a decoy, tampered bytes, or wrong
+// key surface a branded error page and never yield content.
+
+#ifndef NET_URL_REQUEST_DIG_PROTOCOL_HANDLER_H_
+#define NET_URL_REQUEST_DIG_PROTOCOL_HANDLER_H_
+
+#include <memory>
+#include <string>
+
+#include "base/compiler_specific.h"
+#include "net/base/net_export.h"
+#include "net/url_request/url_request_job_factory.h"
+
+class GURL;
+
+namespace net {
+
+class URLRequest;
+class URLRequestJob;
+
+// Implements a ProtocolHandler for DIG Network (dig://) URLs.
+class NET_EXPORT DigProtocolHandler
+    : public URLRequestJobFactory::ProtocolHandler {
+ public:
+  DigProtocolHandler();
+  DigProtocolHandler(const DigProtocolHandler&) = delete;
+  DigProtocolHandler& operator=(const DigProtocolHandler&) = delete;
+
+  std::unique_ptr<URLRequestJob> CreateJob(URLRequest* request) const override;
+  bool IsSafeRedirectTarget(const GURL& location) const override;
+
+  // The DIG JSON-RPC read endpoint. Default: https://rpc.dig.net/.
+  static std::string GetRpcEndpoint();
+};
+
+}  // namespace net
+
+#endif  // NET_URL_REQUEST_DIG_PROTOCOL_HANDLER_H_
