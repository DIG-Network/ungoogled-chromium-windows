+#include "ui/views/view.h"
+#include "url/gurl.h"
+
+namespace dig {
+
+namespace {
+
+// The docked DIG panels are narrow vertical panels (the dig://wallet and
+// dig://shields pages are both designed for a slim column).
+constexpr int kDigPanelWidth = 420;
+
+int DigPanelWidth() {
+  return kDigPanelWidth;
+}
+
+// Builds dig://shields?... with the ACTIVE tab's dig:// identity status, the
+// same query the DigShieldsButton popup used to pass, so the docked panel
+// reflects the page it was opened over. (Snapshot at show-time, like the popup;
+// the page HTML/JS that reads location.search is UNCHANGED.) Kept in lockstep
+// with DigShieldsButton::BuildPanelUrl().
+std::string BuildShieldsUrl(BrowserWindowInterface& browser) {
+  std::string scheme = "web";
+  std::string verified = "0";
+  std::string source = "remote";
+  std::string host;
+
+  if (tabs::TabInterface* tab = browser.GetActiveTabInterface()) {
+    if (content::WebContents* contents = tab->GetContents()) {
+      const GURL& url = contents->GetLastCommittedURL();
+      host = url.host();
+      // SCHEME SPLIT (SYSTEM.md): dig:// = browser-internal pages; chia:// = DIG
+      // Network content (verified by construction — the loader is fail-closed).
+      if (url.SchemeIs("dig")) {
+        scheme = "internal";
+      } else if (url.SchemeIs("chia")) {
+        scheme = "dig";
+        verified = "1";
+        if (DigTabHelper* helper = DigTabHelper::FromWebContents(contents)) {
+          source = helper->served_locally() ? "local" : "remote";
+        }
+      }
+    }
+  }
+
+  return base::StrCat({"dig://shields?scheme=", scheme, "&verified=", verified,
+                       "&source=", source, "&host=",
+                       base::EscapeQueryParamValue(host, /*use_plus=*/false)});
+}
+
+// Side-panel content for dig://wallet: a profile-bound WebView that loads the
+// in-process DIG Wallet UI. The dig:// scheme is served by the DIG
+// URLLoaderFactory, so this renders exactly the page the popup did -- verified +
+// decrypted the same way. The scope is unused (the wallet is profile-scoped).
+std::unique_ptr<views::View> CreateWalletView(Profile* profile,
+                                              SidePanelEntryScope& scope) {
+  auto web_view = std::make_unique<views::WebView>(profile);
+  web_view->LoadInitialURL(GURL("dig://wallet"));
+  return web_view;
+}
+
+// Side-panel content for dig://shields: a profile-bound WebView loading
+// dig://shields with the active tab's dig status as query params (see
+// BuildShieldsUrl). The scope yields the browser window -> active tab.
+std::unique_ptr<views::View> CreateShieldsView(Profile* profile,
+                                               SidePanelEntryScope& scope) {
+  auto web_view = std::make_unique<views::WebView>(profile);
+  web_view->LoadInitialURL(GURL(BuildShieldsUrl(scope.GetBrowserWindowInterface())));
+  return web_view;
+}
+
+void RegisterSurface(SidePanelRegistry* window_registry,
+                     SidePanelEntryId id,
+                     SidePanelEntry::CreateContentCallback factory) {
+  auto entry = std::make_unique<SidePanelEntry>(
+      SidePanelEntry::Key(id), std::move(factory),
+      base::BindRepeating(&DigPanelWidth));
+  // The dig:// surfaces own their header UI, and a std::nullopt-action entry
+  // must NOT get a SidePanelHeaderController (it would CHECK-fail in
+  // SidePanelHelper::GetActionItem). Render header-less; the toolbar button
+  // toggles the panel closed.
+  entry->set_should_show_header(false);
+  window_registry->Register(std::move(entry));
+}
+
+}  // namespace
+
+void RegisterDigSidePanelEntries(Browser* browser,
+                                 SidePanelRegistry* window_registry) {
+  Profile* profile = browser->profile();
+  RegisterSurface(window_registry, SidePanelEntryId::kDigWallet,
+                  base::BindRepeating(&CreateWalletView, profile));
+  RegisterSurface(window_registry, SidePanelEntryId::kDigShields,
+                  base::BindRepeating(&CreateShieldsView, profile));
+}
+
+}  // namespace dig
