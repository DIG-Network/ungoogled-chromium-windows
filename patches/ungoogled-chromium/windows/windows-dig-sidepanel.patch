+#ifndef CHROME_BROWSER_UI_VIEWS_SIDE_PANEL_DIG_SIDE_PANEL_H_
+#define CHROME_BROWSER_UI_VIEWS_SIDE_PANEL_DIG_SIDE_PANEL_H_
+
+class Browser;
+class SidePanelRegistry;
+
+namespace dig {
+
+// DIG Browser: registers the DIG Wallet (dig://wallet) and DIG Shields
+// (dig://shields) surfaces as GLOBAL (window-scoped) side-panel entries, so
+// they dock into Chromium's built-in Side Panel from any tab instead of opening
+// as free-floating popup windows.
+//
+// Each entry's content is a plain views::WebView that LoadInitialURL()s the
+// existing dig:// surface -- the page HTML/JS is UNCHANGED; it is just hosted
+// in the docked panel rather than a separate window. The entries use the
+// kDigWallet / kDigShields ids (side_panel_entry_id.h, std::nullopt action id,
+// mirroring kWebView/kSidePanelDev) and are registered header-less
+// (should_show_header(false)): the dig:// pages carry their own header, and a
+// std::nullopt-action entry must skip SidePanelHeaderController, whose
+// SidePanelHelper::GetActionItem() CHECK-fails on a no-action id.
+//
+// Called from SidePanelHelper::PopulateGlobalEntries(), the single hook where
+// Chromium registers its own global entries (reading list, bookmarks, ...).
+void RegisterDigSidePanelEntries(Browser* browser,
+                                 SidePanelRegistry* window_registry);
+
+}  // namespace dig
+
+#endif  // CHROME_BROWSER_UI_VIEWS_SIDE_PANEL_DIG_SIDE_PANEL_H_
