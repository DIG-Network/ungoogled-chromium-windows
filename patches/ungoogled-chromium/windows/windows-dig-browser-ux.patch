+namespace dig {
+
+namespace {
+
+// Session cache of resolved singleton-tip roots (store_id_hex -> root_hex) so a
+// rootless dig:// page and all its subresources resolve the tip exactly once
+// and share one consistent root. Guarded by a lock since navigation and
+// subresource loader instances may run on different sequences.
+base::Lock& RootCacheLock() {
+  static base::NoDestructor<base::Lock> lock;
+  return *lock;
+}
+std::map<std::string, std::string>& RootCache() {
+  static base::NoDestructor<std::map<std::string, std::string>> cache;
+  return *cache;
+}
+std::optional<std::string> GetCachedRoot(const std::string& store_id) {
+  base::AutoLock lock(RootCacheLock());
+  auto it = RootCache().find(store_id);
+  if (it == RootCache().end()) {
+    return std::nullopt;
+  }
+  return it->second;
+}
+void PutCachedRoot(const std::string& store_id, const std::string& root) {
+  base::AutoLock lock(RootCacheLock());
+  RootCache()[store_id] = root;
+}
+
+// Runs the `dig-resolver` sidecar (shipped next to the browser executable) to
+// resolve a store's CURRENT singleton-tip root from coinset.org — the trusted,
+// chain-anchored source, never the serving node. Returns the 64-hex root, or
+// nullopt on any failure. Blocking: must run on a MayBlock() thread.
+std::optional<std::string> RunTipResolver(const std::string& store_id) {
+  base::FilePath exe_dir;
+  if (!base::PathService::Get(base::DIR_EXE, &exe_dir)) {
+    return std::nullopt;
+  }
+#if BUILDFLAG(IS_WIN)
+  base::CommandLine cmd(exe_dir.AppendASCII("dig-resolver.exe"));
+#else
+  base::CommandLine cmd(exe_dir.AppendASCII("dig-resolver"));
+#endif
+  cmd.AppendArg(store_id);
+  std::string out;
+  if (!base::GetAppOutput(cmd, &out)) {
+    return std::nullopt;
+  }
+  std::string root =
+      base::ToLowerASCII(base::TrimWhitespaceASCII(out, base::TRIM_ALL));
+  if (root.size() != 64) {
+    return std::nullopt;
+  }
+  for (char c : root) {
+    if (!base::IsHexDigit(c)) {
+      return std::nullopt;
+    }
+  }
+  return root;
+}
+
+// Per-window request cap. Kept below the SimpleURLLoader bounded-download cap
+// (kMaxBoundedStringDownloadSize, 5 MiB) once the binary chunk is base64
+// inflated (~4/3x) plus JSON-RPC + proof overhead. 2 MiB binary -> ~2.7 MiB
+// base64, comfortably under 5 MiB.
+constexpr int kRpcChunk = 2 * 1024 * 1024;
+// Hard ceiling on a single resource to bound memory (64 MiB).
+constexpr int64_t kMaxResourceBytes = 64 * 1024 * 1024;
+// Output data pipe capacity.
+constexpr uint32_t kPipeSize = 64 * 1024;
+
+// MIME from the resource key extension (mirrors the extension's ctForPath and
+// net/url_request/dig_protocol_handler.cc MimeForResourceKey).
+std::string MimeForResourceKey(const std::string& resource_key) {
+  std::string rk =
+      resource_key.empty() ? std::string("index.html") : resource_key;
+  size_t dot = rk.find_last_of('.');
+  std::string ext =
+      dot == std::string::npos ? "" : base::ToLowerASCII(rk.substr(dot + 1));
+  if (ext == "html" || ext == "htm") return "text/html";
+  if (ext == "js" || ext == "mjs") return "text/javascript";
+  if (ext == "css") return "text/css";
+  if (ext == "json") return "application/json";
+  if (ext == "png") return "image/png";
+  if (ext == "jpg" || ext == "jpeg") return "image/jpeg";
+  if (ext == "gif") return "image/gif";
+  if (ext == "svg") return "image/svg+xml";
+  if (ext == "webp") return "image/webp";
+  if (ext == "ico") return "image/x-icon";
+  if (ext == "woff") return "font/woff";
+  if (ext == "woff2") return "font/woff2";
+  if (ext == "txt") return "text/plain";
+  if (ext == "pdf") return "application/pdf";
+  if (ext == "mp4") return "video/mp4";
+  if (ext == "webm") return "video/webm";
+  if (ext == "wasm") return "application/wasm";
+  if (ext == "xml") return "application/xml";
+  if (ext == "md") return "text/markdown";
+  return "application/octet-stream";
+}
+
+// Branded DIG error page (clean, brand-purple). Shown on any resolution or
+// verification failure — content is NEVER shown unless it verifies and
+// decrypts. Mirrors net/url_request/dig_protocol_handler.cc ErrorPageHtml.
+std::string ErrorPageHtml(const std::string& message) {
+  return base::StrCat({
+      "<!doctype html><html><head><meta charset=\"utf-8\">"
+      "<meta name=\"color-scheme\" content=\"dark light\">"
+      "<title>DIG Network</title><style>"
+      ":root{color-scheme:dark light}"
+      "html,body{height:100%;margin:0}"
+      "body{display:flex;align-items:center;justify-content:center;"
+      "font-family:'Segoe UI',system-ui,sans-serif;"
+      "background:radial-gradient(1200px 800px at 50% -10%,#1b0b35 0%,#0c0718 60%,#08040f 100%);"
+      "color:#ECE6F7}"
+      ".card{max-width:560px;padding:48px 40px;text-align:center}"
+      ".d{width:88px;height:88px;margin:0 auto 24px;border-radius:22px;"
+      "background:linear-gradient(135deg,#6645EB 0%,#D445EB 100%);"
+      "display:flex;align-items:center;justify-content:center;"
+      "font-weight:800;font-size:46px;color:#fff;"
+      "box-shadow:0 12px 48px rgba(120,53,235,.45)}"
+      "h1{font-size:24px;font-weight:700;margin:0 0 10px}"
+      "p{font-size:15px;line-height:1.6;color:#B9AFD6;margin:0}"
+      ".u{margin-top:18px;font-size:12px;color:#7C6FA6;"
+      "word-break:break-all;font-family:ui-monospace,monospace}"
+      "</style></head><body><div class=\"card\">"
+      "<div class=\"d\">D</div>"
+      "<h1>Couldn&rsquo;t load this DIG resource</h1>"
+      "<p>", message, "</p>"
+      "<div class=\"u\">dig://</div>"
+      "</div></body></html>"});
+}
+
+
+// ---------------------------------------------------------------------------
+// DigURLLoader: self-owned network::mojom::URLLoader that drives the
+// rpc.dig.net read path for a single dig:// request.
+//
+// Ported from net::DigProtocolJob (net/url_request/dig_protocol_handler.cc).
+// Two endpoints differ from the original job:
+//   * RPC sink: a fresh network::SimpleURLLoader per offset/length window
+//     (DownloadToString over the captured browser-process SharedURLLoader-
+//     Factory) replaces the nested net::URLRequest. Each response is fed into
+//     the same HandleRpcWindowComplete parser; the windowing loop is unchanged.
+//   * Output sink: a mojo data pipe + DataPipeProducer/StringDataSource streams
+//     the decrypted bytes to the URLLoaderClient instead of URLRequestJob reads.
+// TODO(dig): the fetch/verify/decrypt reassembly core is currently a port-by-
+// copy of DigProtocolJob; extract a shared helper consumed by both paths.
+// ---------------------------------------------------------------------------
+class DigURLLoader : public network::mojom::URLLoader {
+ public:
+  static void CreateAndStart(
+      scoped_refptr<network::SharedURLLoaderFactory> network_loader_factory,
+      const network::ResourceRequest& request,
+      mojo::PendingReceiver<network::mojom::URLLoader> loader,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client) {
+    // Owns itself; lives until the client gives up (mojo disconnect) or the
+    // response (or branded error page) has been fully delivered.
+    auto* self = new DigURLLoader(std::move(network_loader_factory),
+                                  std::move(loader), std::move(client));
+    self->Start(request.url);
+  }
+
+  DigURLLoader(const DigURLLoader&) = delete;
+  DigURLLoader& operator=(const DigURLLoader&) = delete;
+
+  // network::mojom::URLLoader (no-ops — a dig:// load takes none of these):
+  void FollowRedirect(
+      const std::vector<std::string>& removed_headers,
+      const net::HttpRequestHeaders& modified_headers,
+      const net::HttpRequestHeaders& modified_cors_exempt_headers,
+      const std::optional<GURL>& new_url) override {}
+  void SetPriority(net::RequestPriority priority,
+                   int32_t intra_priority_value) override {}
+
+ private:
+  DigURLLoader(
+      scoped_refptr<network::SharedURLLoaderFactory> network_loader_factory,
+      mojo::PendingReceiver<network::mojom::URLLoader> loader,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client)
+      : network_loader_factory_(std::move(network_loader_factory)) {
+    receiver_.Bind(std::move(loader));
+    receiver_.set_disconnect_handler(base::BindOnce(
+        &DigURLLoader::OnMojoDisconnect, base::Unretained(this)));
+    client_.Bind(std::move(client));
+  }
+
+  ~DigURLLoader() override = default;
+
+  void Start(const GURL& url) {
+    // dig://home is the DIG Browser's own home page (the new-tab page points
+    // here). It is a trusted browser-internal resource embedded in the binary,
+    // NOT on-chain content, so it is served directly without resolve/verify/
+    // decrypt. Every OTHER dig:// host is a store id and stays fully verified.
+    if (url.host_piece() == "home") {
+      output_ = kDigHomeHtml;
+      mime_type_ = "text/html";
+      verified_ = false;  // a local page, not chain-verified content
+      SendResponse();
+      return;
+    }
+    // dig://wallet opens the built-in Chia wallet, served in-process by the DIG
+    // runtime over loopback (an interactive web UI). Redirect to it.
+    if (url.host_piece() == "wallet") {
+      output_ =
+          "<!doctype html><meta charset=\"utf-8\">"
+          "<meta http-equiv=\"refresh\" content=\"0;url=http://127.0.0.1:9777/\">"
+          "<title>DIG Wallet</title>"
+          "<body style=\"margin:0;background:#0b0618\"></body>";
+      mime_type_ = "text/html";
+      verified_ = false;
+      SendResponse();
+      return;
+    }
+    // dig://settings opens the DIG protocol settings page (local-cache
+    // threshold, etc.), served in-process by the DIG runtime over loopback.
+    if (url.host_piece() == "settings") {
+      output_ =
+          "<!doctype html><meta charset=\"utf-8\">"
+          "<meta http-equiv=\"refresh\" content=\"0;url=http://127.0.0.1:9777/settings\">"
+          "<title>DIG Settings</title>"
+          "<body style=\"margin:0;background:#0b0c0e\"></body>";
+      mime_type_ = "text/html";
+      verified_ = false;
+      SendResponse();
+      return;
+    }
+    // The browser navigates the canonical host-bearing form
+    // dig://[<root>.]<store_id>/<resource>; relative subresources resolve
+    // against the same host, so parse the store/root from the host and the
+    // resource from the path.
+    parsed_ = net::dig::ParseDigHostUrl(url.host(), url.path(), url.query());
+    if (!parsed_.valid) {
+      FinishWithError("That dig:// address isn't a valid DIG URN.");
+      return;
+    }
+    chain_ = parsed_.chain.empty() ? "chia" : parsed_.chain;
+    resource_key_ =
+        parsed_.resource_key.empty() ? "index.html" : parsed_.resource_key;
+    retrieval_key_ = net::dig::RetrievalKeyHex(chain_, parsed_.store_id,
+                                               parsed_.resource_key);
+
+    // Explicit root in the URL → verify against it directly.
+    if (parsed_.root_hash.has_value()) {
+      root_ = *parsed_.root_hash;
+      StartRpcWindow(0);
+      return;
+    }
+    // Rootless dig:// — resolve the store's CURRENT singleton-tip root
+    // (chain-anchored, from coinset.org) and verify the served content against
+    // THAT root, never the serving node's claim. Cached per store so the page's
+    // subresources don't each re-resolve.
+    if (std::optional<std::string> cached = GetCachedRoot(parsed_.store_id)) {
+      root_ = *cached;
+      StartRpcWindow(0);
+      return;
+    }
+    // Resolve via the local dig-node (dig.getAnchoredRoot) over the same HTTP
+    // endpoint we fetch content from. This replaces spawning the dig-resolver
+    // subprocess, which the browser-process sandbox blocks (GetAppOutput fails),
+    // and reuses the node the browser already depends on. The subprocess remains
+    // only as a last-resort fallback.
+    StartRootResolve();
+  }
+
+  // Resolve a rootless URN's chain-anchored tip root by calling the in-process
+  // DIG runtime (dig.getAnchoredRoot) DIRECTLY via FFI on a MayBlock thread —
+  // the browser process IS the node, so there is no loopback server to POST to.
+  void StartRootResolve() {
+    base::Value::Dict params;
+    params.Set("store_id", parsed_.store_id);
+    base::Value::Dict body;
+    body.Set("jsonrpc", "2.0");
+    body.Set("id", 1);
+    body.Set("method", "dig.getAnchoredRoot");
+    body.Set("params", std::move(params));
+    std::string json;
+    base::JSONWriter::Write(base::Value(std::move(body)), &json);
+    base::ThreadPool::PostTaskAndReplyWithResult(
+        FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_BLOCKING},
+        base::BindOnce(&dig::CallDigRpc, std::move(json)),
+        base::BindOnce(&DigURLLoader::OnNodeRootResolved,
+                       weak_factory_.GetWeakPtr()));
+  }
+
+  void OnNodeRootResolved(std::string body) {
+    if (!body.empty()) {
+      std::optional<base::Value> parsed = base::JSONReader::Read(body);
+      if (parsed && parsed->is_dict()) {
+        if (const base::Value::Dict* result =
+                parsed->GetDict().FindDict("result")) {
+          const std::string* r = result->FindString("root");
+          if (r && r->size() == 64) {
+            OnRootResolved(*r);
+            return;
+          }
+        }
+      }
+    }
+    // The in-process runtime couldn't resolve (chain/coinset error) — last resort.
+    FallbackResolveRoot();
+  }
+
+  // Last-resort: the bundled dig-resolver subprocess. Rarely needed now that the
+  // in-process runtime resolves directly; kept for resilience.
+  void FallbackResolveRoot() {
+    base::ThreadPool::PostTaskAndReplyWithResult(
+        FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_BLOCKING},
+        base::BindOnce(&RunTipResolver, parsed_.store_id),
+        base::BindOnce(&DigURLLoader::OnRootResolved,
+                       weak_factory_.GetWeakPtr()));
+  }
+
+  void OnRootResolved(std::optional<std::string> root) {
+    if (!root) {
+      FinishWithError(
+          "Couldn't resolve this store's latest root from the chain "
+          "(coinset.org). Try again, or put an explicit root in the URL.");
+      return;
+    }
+    PutCachedRoot(parsed_.store_id, *root);
+    root_ = *root;
+    StartRpcWindow(0);
+  }
+
+  void StartRpcWindow(int64_t offset) {
+    // Build the JSON-RPC 2.0 dig.getContent request body.
+    base::Value::Dict params;
+    params.Set("store_id", parsed_.store_id);
+    params.Set("root", root_);
+    params.Set("retrieval_key", retrieval_key_);
+    params.Set("offset", static_cast<double>(offset));
+    params.Set("length", kRpcChunk);
+
+    base::Value::Dict body;
+    body.Set("jsonrpc", "2.0");
+    body.Set("id", 1);
+    body.Set("method", "dig.getContent");
+    body.Set("params", std::move(params));
+
+    std::string json;
+    base::JSONWriter::Write(base::Value(std::move(body)), &json);
+
+    current_offset_ = offset;
+    // Call the in-process DIG runtime DIRECTLY via FFI on a MayBlock thread —
+    // the browser process IS the node. No SimpleURLLoader, no loopback server.
+    base::ThreadPool::PostTaskAndReplyWithResult(
+        FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_BLOCKING},
+        base::BindOnce(&dig::CallDigRpc, std::move(json)),
+        base::BindOnce(&DigURLLoader::OnRpcWindowDownloaded,
+                       weak_factory_.GetWeakPtr()));
+  }
+
+  void OnRpcWindowDownloaded(std::string response_body) {
+    if (response_body.empty()) {
+      FinishWithError("Couldn't reach the DIG content network.");
+      return;
+    }
+    rpc_body_ = std::move(response_body);
+    HandleRpcWindowComplete();
+  }
+
+  void HandleRpcWindowComplete() {
+    std::optional<base::Value> parsed = base::JSONReader::Read(rpc_body_);
+    if (!parsed || !parsed->is_dict()) {
+      FinishWithError("DIG RPC returned a malformed response.");
+      return;
+    }
+    const base::Value::Dict& root = parsed->GetDict();
+    if (const base::Value::Dict* err = root.FindDict("error")) {
+      const std::string* msg = err->FindString("message");
+      FinishWithError(msg ? *msg : "DIG RPC error.");
+      return;
+    }
+    const base::Value::Dict* result = root.FindDict("result");
+    if (!result) {
+      FinishWithError("DIG RPC returned no data.");
+      return;
+    }
+
+    // Where the node served this from: "local" (this device's cache) or
+    // "remote" (rpc.dig.net). Surfaced to the omnibox as the "local" chip.
+    if (const std::string* src = result->FindString("source")) {
+      source_ = *src;
+    }
+
+    // First window: allocate the output buffer and capture chunk_lens.
+    if (total_length_ < 0) {
+      std::optional<double> total = result->FindDouble("total_length");
+      if (!total || *total < 0 || *total > kMaxResourceBytes) {
+        FinishWithError("DIG resource is missing or too large.");
+        return;
+      }
+      total_length_ = static_cast<int64_t>(*total);
+      ciphertext_.assign(static_cast<size_t>(total_length_), 0);
+      if (const base::Value::List* lens = result->FindList("chunk_lens")) {
+        for (const base::Value& v : *lens) {
+          if (v.is_int()) {
+            chunk_lens_.push_back(static_cast<uint32_t>(v.GetInt()));
+          } else if (v.is_double()) {
+            chunk_lens_.push_back(static_cast<uint32_t>(v.GetDouble()));
+          }
+        }
+      }
+    }
+
+    // ciphertext (base64) lands at result.offset within the buffer.
+    const std::string* ct_b64 = result->FindString("ciphertext");
+    if (ct_b64 && !ct_b64->empty()) {
+      std::string decoded;
+      if (!base::Base64Decode(*ct_b64, &decoded)) {
+        FinishWithError("DIG RPC returned malformed ciphertext.");
+        return;
+      }
+      int64_t at = static_cast<int64_t>(result->FindDouble("offset").value_or(
+          static_cast<double>(current_offset_)));
+      int64_t writable =
+          std::max<int64_t>(0, std::min<int64_t>(
+              static_cast<int64_t>(decoded.size()), total_length_ - at));
+      if (at >= 0 && at + writable <= total_length_) {
+        std::memcpy(ciphertext_.data() + at, decoded.data(),
+                    static_cast<size_t>(writable));
+      }
+    }
+
+    // The inclusion proof is the base64 string for the whole resource.
+    if (const std::string* proof = result->FindString("inclusion_proof")) {
+      if (!proof->empty()) {
+        proof_b64_ = *proof;
+      }
+    }
+
+    bool complete = result->FindBool("complete").value_or(false);
+    std::optional<double> next = result->FindDouble("next_offset");
+    if (complete || !next.has_value()) {
+      FinishResolve();
+      return;
+    }
+    StartRpcWindow(static_cast<int64_t>(*next));
+  }
+
+  void FinishResolve() {
+
+    // Verify the Merkle inclusion proof, then derive the key and decrypt.
+    // Verification is required: a failed proof or a decrypt tag failure means
+    // we serve NO content (fail closed).
+    verified_ = net::dig::VerifyInclusion(ciphertext_, proof_b64_, root_);
+    if (!verified_) {
+      FinishWithError(
+          "DIG content failed its on-chain integrity check (Merkle proof). "
+          "It may be tampered or a decoy.");
+      return;
+    }
+
+    const std::string canonical_urn = net::dig::CanonicalRootlessUrn(
+        chain_, parsed_.store_id, parsed_.resource_key);
+    uint8_t key[32];
+    if (!net::dig::DeriveContentKey(canonical_urn, parsed_.salt, key)) {
+      FinishWithError("DIG content key could not be derived.");
+      return;
+    }
+
+    std::vector<uint8_t> plaintext;
+    if (!net::dig::DecryptResource(key, ciphertext_, chunk_lens_, &plaintext)) {
+      FinishWithError(
+          "DIG content could not be decrypted (decoy, wrong key, or tamper).");
+      return;
+    }
+
+    output_.assign(plaintext.begin(), plaintext.end());
+    mime_type_ = MimeForResourceKey(resource_key_);
+    SendResponse();
+  }
+
+  void FinishWithError(const std::string& message) {
+    output_ = ErrorPageHtml(message);
+    mime_type_ = "text/html";
+    verified_ = false;
+    SendResponse();
+  }
+
+  // Build the response head, open the data pipe, and stream `output_`.
+  void SendResponse() {
+    if (!client_.is_bound()) {
+      MaybeDeleteSelf();
+      return;
+    }
+
+    auto head = network::mojom::URLResponseHead::New();
+    head->mime_type = mime_type_;
+    head->content_length = static_cast<int64_t>(output_.size());
+    std::string raw_headers =
+        base::StrCat({"HTTP/1.1 200 OK\r\nContent-Type: ", mime_type_,
+                      "\r\nX-Dig-Verified: ", verified_ ? "true" : "false",
+                      "\r\nX-Dig-Source: ", source_.empty() ? "remote" : source_,
+                      "\r\n\r\n"});
+    head->headers = base::MakeRefCounted<net::HttpResponseHeaders>(
+        net::HttpUtil::AssembleRawHeaders(raw_headers));
+
+    mojo::ScopedDataPipeProducerHandle producer_handle;
+    mojo::ScopedDataPipeConsumerHandle consumer_handle;
+    if (mojo::CreateDataPipe(kPipeSize, producer_handle, consumer_handle) !=
+        MOJO_RESULT_OK) {
+      client_->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_INSUFFICIENT_RESOURCES));
+      client_.reset();
+      MaybeDeleteSelf();
+      return;
+    }
+
+    client_->OnReceiveResponse(std::move(head), std::move(consumer_handle),
+                               std::nullopt);
+
+    data_producer_ =
+        std::make_unique<mojo::DataPipeProducer>(std::move(producer_handle));
+    // The body bytes (output_) outlive the write, so STAYS_VALID is safe.
+    auto source = std::make_unique<mojo::StringDataSource>(
+        base::span<const char>(output_.data(), output_.size()),
+        mojo::StringDataSource::AsyncWritingMode::
+            STRING_STAYS_VALID_UNTIL_COMPLETION);
+    // Raw pointer is valid: data_producer_ is owned by `this` and outlives the
+    // write; the callback either deletes `this` or is never invoked.
+    mojo::DataPipeProducer* producer = data_producer_.get();
+    producer->Write(std::move(source),
+                    base::BindOnce(&DigURLLoader::OnBodyWritten,
+                                   weak_factory_.GetWeakPtr()));
+  }
+
+  void OnBodyWritten(MojoResult result) {
+    data_producer_.reset();
+    if (!client_.is_bound()) {
+      MaybeDeleteSelf();
+      return;
+    }
+    if (result != MOJO_RESULT_OK) {
+      client_->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_FAILED));
+      client_.reset();
+      MaybeDeleteSelf();
+      return;
+    }
+    network::URLLoaderCompletionStatus status(net::OK);
+    status.encoded_data_length = static_cast<int64_t>(output_.size());
+    status.encoded_body_length = static_cast<int64_t>(output_.size());
+    status.decoded_body_length = static_cast<int64_t>(output_.size());
+    client_->OnComplete(status);
+    client_.reset();
+    MaybeDeleteSelf();
+  }
+
+  void OnMojoDisconnect() {
+    data_producer_.reset();
+    client_.reset();
+    receiver_.reset();
+    MaybeDeleteSelf();
+  }
+
+  void MaybeDeleteSelf() {
+    if (!receiver_.is_bound() && !client_.is_bound()) {
+      delete this;
+    }
+  }
+
+  mojo::Receiver<network::mojom::URLLoader> receiver_{this};
+  mojo::Remote<network::mojom::URLLoaderClient> client_;
+
+  // Captured at construction; retained for parity with the factory plumbing.
+  // The dig:// read path now calls the in-process DIG runtime directly (FFI),
+  // so this is no longer used for content fetches.
+  [[maybe_unused]] scoped_refptr<network::SharedURLLoaderFactory>
+      network_loader_factory_;
+
+  net::dig::ParsedUrn parsed_;
+  std::string chain_;
+  std::string resource_key_;
+  std::string root_;
+  std::string retrieval_key_;
+
+  // The latest in-process RPC response body being reassembled.
+  std::string rpc_body_;
+  int64_t current_offset_ = 0;
+
+  // Reassembly state.
+  int64_t total_length_ = -1;
+  std::vector<uint8_t> ciphertext_;
+  std::vector<uint32_t> chunk_lens_;
+  std::string proof_b64_;
+
+  // Output (decrypted plaintext, or branded error HTML) + its pipe producer.
+  std::string output_;
+  std::string mime_type_ = "text/html";
+  bool verified_ = false;
+  // "local" (served from this device's DIG cache) or "remote"/"" (from
+  // rpc.dig.net). Emitted as the X-Dig-Source header → the omnibox "local" chip.
+  std::string source_;
+  std::unique_ptr<mojo::DataPipeProducer> data_producer_;
+
+  base::WeakPtrFactory<DigURLLoader> weak_factory_{this};
+};
+
+}  // namespace
+
+// static
+mojo::PendingRemote<network::mojom::URLLoaderFactory> DigURLLoaderFactory::Create(
+    content::BrowserContext* browser_context) {
+  mojo::PendingRemote<network::mojom::URLLoaderFactory> pending_remote;
+
+  scoped_refptr<network::SharedURLLoaderFactory> network_loader_factory =
+      browser_context->GetDefaultStoragePartition()
+          ->GetURLLoaderFactoryForBrowserProcess();
+
+  // The DigURLLoaderFactory deletes itself when there are no more receivers —
+  // see network::SelfDeletingURLLoaderFactory::OnDisconnect.
+  new DigURLLoaderFactory(std::move(network_loader_factory),
+                          pending_remote.InitWithNewPipeAndPassReceiver());
+
+  return pending_remote;
+}
+
+DigURLLoaderFactory::DigURLLoaderFactory(
+    scoped_refptr<network::SharedURLLoaderFactory> network_loader_factory,
+    mojo::PendingReceiver<network::mojom::URLLoaderFactory> factory_receiver)
+    : network::SelfDeletingURLLoaderFactory(std::move(factory_receiver)),
+      network_loader_factory_(std::move(network_loader_factory)) {}
+
+DigURLLoaderFactory::~DigURLLoaderFactory() = default;
+
+void DigURLLoaderFactory::CreateLoaderAndStart(
+    mojo::PendingReceiver<network::mojom::URLLoader> loader,
+    int32_t request_id,
+    uint32_t options,
+    const network::ResourceRequest& request,
+    mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+    const net::MutableNetworkTrafficAnnotationTag& traffic_annotation) {
+  DigURLLoader::CreateAndStart(network_loader_factory_, request,
+                               std::move(loader), std::move(client));
+}
