+// Traffic annotation for the loopback POSTs/GETs to a local standalone dig-node.
+// These never leave the machine (dig.local / localhost), carry no user identity
+// (credentials omitted), and only move blind ciphertext + Merkle proofs which
+// are re-verified locally.
+const net::NetworkTrafficAnnotationTag kDigNodeTrafficAnnotation =
+    net::DefineNetworkTrafficAnnotation("dig_local_node_rpc", R"(
+        semantics {
+          sender: "DIG Browser chia:// loader"
+          description:
+            "Reads DIG content from a local standalone dig-node running on this "
+            "machine (http://dig.local or http://localhost:8080) when present, "
+            "as the preferred source over the browser's in-process node. The "
+            "response (blind ciphertext + a Merkle inclusion proof) is verified "
+            "against the on-chain root and decrypted locally."
+          trigger: "Navigating to a chia:// address or loading a chia:// subresource."
+          data: "A JSON-RPC dig.getContent/dig.getAnchoredRoot request (store id, "
+                "root, retrieval key, offset/length). No user identity."
+          destination: LOCAL
+        }
+        policy {
+          cookies_allowed: NO
+          setting: "Disable with the --disable-local-dig-node command-line switch."
+          policy_exception_justification: "Loopback-only; no off-machine traffic."
+        })");
