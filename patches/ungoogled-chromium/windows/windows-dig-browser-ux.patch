   pref_change_registrar_.Add(
       prefs::kUserColor, base::BindRepeating(&ThemeService::NotifyThemeChanged,
                                              base::Unretained(this)));
+
+  // DIG Browser default theme: on a fresh profile that is still on the default
+  // theme with no user color chosen, seed the GM3 autogenerated theme from the
+  // DIG brand purple (#5800D6) in dark mode — exactly as the color picker would.
+  // This gives the browser a subtle, cohesive DIG look out of the box while
+  // leaving the user free to change it (any later choice sets a user color or a
+  // custom theme id, so this never runs again for that profile).
+  if (UsingDefaultTheme() &&
+      !CurrentThemeUserColor(profile_->GetPrefs()).has_value()) {
+    SetBrowserColorScheme(BrowserColorScheme::kDark);
+    SetUserColorAndBrowserColorVariant(
+        SkColorSetRGB(0x58, 0x00, 0xD6),
+        ui::mojom::BrowserColorVariant::kTonalSpot);
+  }
 }
 
