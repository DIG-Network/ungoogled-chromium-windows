+// Per-window request cap. Kept below the SimpleURLLoader bounded-download cap
+// (kMaxBoundedStringDownloadSize, 5 MiB) once the binary chunk is base64
+// inflated (~4/3x) plus JSON-RPC + proof overhead. 2 MiB binary -> ~2.7 MiB
+// base64, comfortably under 5 MiB.
+constexpr int kRpcChunk = 2 * 1024 * 1024;
+// Hard ceiling on a single resource to bound memory (64 MiB).
+constexpr int64_t kMaxResourceBytes = 64 * 1024 * 1024;
+// Output data pipe capacity.
+constexpr uint32_t kPipeSize = 64 * 1024;
+
+// ---------------------------------------------------------------------------
+// Source resolution (the CONSUMER side of the serve/consume split, SYSTEM.md →
+// "Roles — serving vs consuming"). The chia:// read path tries, IN ORDER:
+//   1. a LOCAL standalone dig-node's read RPC if reachable — preferred
+//      (local/offline/contributes), addressed http://dig.local FIRST then
+//      http://localhost:<port> (default 8080);
+//   2. else the browser's OWN in-process dig-node (the FFI dig::CallDigRpc),
+//      which itself reaches rpc.dig.net when it has no cached capsule.
+// Whichever source serves the bytes, the loader ALWAYS verifies the Merkle
+// proof against the on-chain root and decrypts client-side, fail-closed — the
+// source is NEVER trusted. The PURE policy (ordering/port/host/probe-path/TTL)
+// is mirrored from dig/node/dig_source_resolution.mjs (which carries the Node
+// tests for it); change BOTH in lockstep.
+// ---------------------------------------------------------------------------
+
+// dig-node's canonical local addresses, in preference order. dig.local has NO
+// port (the dig-installer maps it to the node's privileged :80 loopback
+// listener); the localhost listener uses the default 8080.
+constexpr char kDigLocalBase[] = "http://dig.local";
+constexpr char kLocalhostBase[] = "http://localhost:8080";
+// The node serves JSON-RPC at POST "/" and a cheap liveness probe at GET
+// "/health" (dig-companion server.rs). We probe /health, never a content
+// method, so a failed probe is fast and side-effect free.
+constexpr char kHealthPath[] = "/health";
+// Cap on a single local-node JSON-RPC response (a windowed dig.getContent reply
+// is ~kRpcChunk base64-inflated + proof overhead). 5 MiB matches the per-window
+// reasoning above and stays within SimpleURLLoader's bounded-download limit.
+constexpr size_t kLocalNodeMaxResponse = 5 * 1024 * 1024;
+// How long a reachability verdict is trusted before re-probing (5s): short
+// enough that starting/stopping the node is noticed quickly, long enough that a
+// page's many subresources never each re-probe a down node.
+constexpr base::TimeDelta kProbeTtl = base::Seconds(5);
+
+// Command-line switch that DISABLES consuming from a local standalone dig-node
+// (the browser then consumes via its in-process node only — always fully
+// functional, a consumer needs no local node). Mirrors the user setting; the
+// default (switch absent) prefers the local node.
+constexpr char kDisableLocalDigNodeSwitch[] = "disable-local-dig-node";
+
+bool LocalNodePreferred() {
+  return !base::CommandLine::ForCurrentProcess()->HasSwitch(
+      kDisableLocalDigNodeSwitch);
+}
+
+// The ordered local-node base URLs to try, honoring the setting. Empty when the
+// local node is disabled.
+std::vector<std::string> LocalNodeCandidates() {
+  if (!LocalNodePreferred()) {
+    return {};
+  }
+  return {kDigLocalBase, kLocalhostBase};
+}
+
+// A live dig-node /health body confirms BOTH status:"ok" and mode:"local-node"
+// (so some other service squatting the port is rejected). Anything malformed →
+// false (fail safe: fall through to the in-process node).
+bool IsHealthyDigNode(const std::string& body) {
+  std::optional<base::Value> v =
+      base::JSONReader::Read(body, base::JSON_PARSE_RFC);
+  if (!v || !v->is_dict()) {
+    return false;
+  }
+  const base::DictValue& d = v->GetDict();
+  const std::string* status = d.FindString("status");
+  const std::string* mode = d.FindString("mode");
+  return status && *status == "ok" && mode && *mode == "local-node";
+}
+
+// Short-TTL reachability memo, keyed by base URL, shared across loader
+// instances (a navigation + all its subresources). Mirrors ReachabilityMemo in
+// dig_source_resolution.mjs: probe a given local node at most once per
+// kProbeTtl rather than on every subresource.
+base::Lock& ProbeMemoLock() {
+  static base::NoDestructor<base::Lock> lock;
+  return *lock;
+}
+std::map<std::string, std::pair<bool, base::TimeTicks>>& ProbeMemo() {
+  static base::NoDestructor<std::map<std::string, std::pair<bool, base::TimeTicks>>>
+      memo;
+  return *memo;
+}
+// Returns the cached verdict for `base_url` if still fresh, else nullopt.
+std::optional<bool> GetProbeVerdict(const std::string& base_url) {
+  base::AutoLock lock(ProbeMemoLock());
+  auto it = ProbeMemo().find(base_url);
+  if (it == ProbeMemo().end()) {
+    return std::nullopt;
+  }
+  if (base::TimeTicks::Now() - it->second.second >= kProbeTtl) {
+    return std::nullopt;  // stale
+  }
+  return it->second.first;
+}
+void PutProbeVerdict(const std::string& base_url, bool reachable) {
+  base::AutoLock lock(ProbeMemoLock());
+  ProbeMemo()[base_url] = {reachable, base::TimeTicks::Now()};
+}
