+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/dig/dig_tab_helper.h"
+
+#include "content/public/browser/navigation_handle.h"
+#include "net/http/http_response_headers.h"
+#include "url/url_constants.h"
+
+namespace dig {
+
+DigTabHelper::DigTabHelper(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<DigTabHelper>(*web_contents) {}
+
+DigTabHelper::~DigTabHelper() = default;
+
+void DigTabHelper::DidFinishNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!navigation_handle->IsInPrimaryMainFrame() ||
+      !navigation_handle->HasCommitted()) {
+    return;
+  }
+  served_locally_ = false;
+  if (navigation_handle->GetURL().SchemeIs(url::kDigScheme)) {
+    const net::HttpResponseHeaders* headers =
+        navigation_handle->GetResponseHeaders();
+    if (headers && headers->HasHeaderValue("X-Dig-Source", "local")) {
+      served_locally_ = true;
+    }
+  }
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(DigTabHelper);
+
+}  // namespace dig
