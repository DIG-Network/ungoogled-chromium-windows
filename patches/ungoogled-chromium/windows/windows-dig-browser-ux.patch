+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_DIG_DIG_TAB_HELPER_H_
+#define CHROME_BROWSER_DIG_DIG_TAB_HELPER_H_
+
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/browser/web_contents_user_data.h"
+
+namespace content {
+class NavigationHandle;
+}
+
+namespace dig {
+
+// Per-tab: remembers whether the current dig:// main document was served from
+// this device's local DIG cache (response header "X-Dig-Source: local") so the
+// omnibox can show a "local" chip. Reset on every primary main-frame navigation.
+class DigTabHelper : public content::WebContentsObserver,
+                     public content::WebContentsUserData<DigTabHelper> {
+ public:
+  DigTabHelper(const DigTabHelper&) = delete;
+  DigTabHelper& operator=(const DigTabHelper&) = delete;
+  ~DigTabHelper() override;
+
+  bool served_locally() const { return served_locally_; }
+
+  // content::WebContentsObserver:
+  void DidFinishNavigation(content::NavigationHandle* navigation_handle) override;
+
+ private:
+  explicit DigTabHelper(content::WebContents* web_contents);
+  friend class content::WebContentsUserData<DigTabHelper>;
+
+  bool served_locally_ = false;
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+}  // namespace dig
+
+#endif  // CHROME_BROWSER_DIG_DIG_TAB_HELPER_H_
--- /dev/null
+++ b/chrome/browser/dig/dig_tab_helper.cc
@@ -0,0 +1,37 @@
+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/dig/dig_tab_helper.h"
+
+#include "content/public/browser/navigation_handle.h"
+#include "net/http/http_response_headers.h"
+#include "url/url_constants.h"
+
+namespace dig {
+
+DigTabHelper::DigTabHelper(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<DigTabHelper>(*web_contents) {}
+
+DigTabHelper::~DigTabHelper() = default;
+
+void DigTabHelper::DidFinishNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!navigation_handle->IsInPrimaryMainFrame() ||
+      !navigation_handle->HasCommitted()) {
+    return;
+  }
+  served_locally_ = false;
+  if (navigation_handle->GetURL().SchemeIs(url::kDigScheme)) {
+    const net::HttpResponseHeaders* headers =
+        navigation_handle->GetResponseHeaders();
+    if (headers && headers->HasHeaderValue("X-Dig-Source", "local")) {
+      served_locally_ = true;
+    }
+  }
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(DigTabHelper);
+
+}  // namespace dig
