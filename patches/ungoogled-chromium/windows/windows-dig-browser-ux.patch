+namespace {
+// Width of the docked DIG Wallet side panel, in DIP. Matches Chromium's default
+// side-panel feel (slim, fixed) and the wallet UI's intended layout.
+constexpr int kWalletPanelWidth = 420;
+// Size of the popped-out (free-floating) wallet window.
+constexpr int kWalletPopoutWidth = 420;
+constexpr int kWalletPopoutHeight = 720;
+}  // namespace
+
+void HomeButton::OpenDigWallet(const ui::Event& event) {
+  if (!profile_) {
+    return;
+  }
+
+  // Alt+click toggles which edge the panel docks to (persisted per profile),
+  // then (re)opens the panel on the new side.
+  if (prefs_ && (event.flags() & ui::EF_ALT_DOWN)) {
+    prefs_->SetBoolean("dig.wallet_panel.dock_left",
+                       !prefs_->GetBoolean("dig.wallet_panel.dock_left"));
+  }
+
+  // Anchor the panel to the browser window this button lives in.
+  gfx::Rect window_bounds;
+  if (GetWidget()) {
+    window_bounds = GetWidget()->GetWindowBoundsInScreen();
+  }
+
+  // Shift+click pops the wallet OUT as its own free-floating window (not docked
+  // to an edge), centered over the browser window.
+  if ((event.flags() & ui::EF_SHIFT_DOWN) || window_bounds.IsEmpty()) {
+    gfx::Rect popout(kWalletPopoutWidth, kWalletPopoutHeight);
+    if (!window_bounds.IsEmpty()) {
+      popout.set_x(window_bounds.x() +
+                   (window_bounds.width() - kWalletPopoutWidth) / 2);
+      popout.set_y(window_bounds.y() +
+                   (window_bounds.height() - kWalletPopoutHeight) / 2);
+    }
+    ShowWalletWindow(popout);
+    return;
+  }
+
+  // Default: dock the panel to an edge of the browser window, full height.
+  const bool dock_left =
+      prefs_ && prefs_->GetBoolean("dig.wallet_panel.dock_left");
+  gfx::Rect docked(kWalletPanelWidth, window_bounds.height());
+  docked.set_y(window_bounds.y());
+  docked.set_x(dock_left ? window_bounds.x()
+                         : window_bounds.right() - kWalletPanelWidth);
+  ShowWalletWindow(docked);
+}
+
+void HomeButton::ShowWalletWindow(const gfx::Rect& bounds) {
+  // Open chia://wallet (the in-process DIG Wallet UI) in a minimal-chrome popup
+  // window placed at `bounds`. NEW_POPUP with the default window_action
+  // auto-shows the window; the position + size come from window_features.
+  NavigateParams params(profile_.get(), GURL("chia://wallet"),
+                        ui::PAGE_TRANSITION_AUTO_BOOKMARK);
+  params.disposition = WindowOpenDisposition::NEW_POPUP;
+  params.window_features.has_x = true;
+  params.window_features.has_y = true;
+  params.window_features.has_width = true;
+  params.window_features.has_height = true;
+  params.window_features.bounds = bounds;
+  Navigate(&params);
+}
+
