@@ -0,0 +1,92 @@
+// Copyright (c) 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/dig/dig_native_runtime.h"
+
+#include "base/base_paths.h"
+#include "base/files/file_path.h"
+#include "base/native_library.h"
+#include "base/no_destructor.h"
+#include "base/path_service.h"
+#include "base/synchronization/lock.h"
+
+namespace dig {
+namespace {
+
+// C-ABI exported by dig_runtime.dll (see crates/dig-runtime).
+using DigRuntimeStartFn = void (*)();
+using DigRpcFn = char* (*)(const char*);
+using DigFreeFn = void (*)(char*);
+
+struct DigRuntimeLib {
+  DigRuntimeStartFn start = nullptr;
+  DigRpcFn rpc = nullptr;
+  DigFreeFn free_fn = nullptr;
+  bool attempted = false;
+};
+
+DigRuntimeLib& Lib() {
+  // Trivially destructible (just function pointers + a flag), so a plain
+  // function-local static is correct here (base::NoDestructor rejects trivial T).
+  static DigRuntimeLib lib;
+  return lib;
+}
+
+base::Lock& LoadLock() {
+  static base::NoDestructor<base::Lock> lock;
+  return *lock;
+}
+
+// Resolve dig_runtime.dll + its exports exactly once (thread-safe). The library
+// is intentionally never unloaded — the DIG runtime runs for the browser's life.
+void EnsureLoaded() {
+  base::AutoLock guard(LoadLock());
+  DigRuntimeLib& lib = Lib();
+  if (lib.attempted) {
+    return;
+  }
+  lib.attempted = true;
+  base::FilePath exe_dir;
+  if (!base::PathService::Get(base::DIR_EXE, &exe_dir)) {
+    return;
+  }
+  base::NativeLibraryLoadError error;
+  base::NativeLibrary native = base::LoadNativeLibrary(
+      exe_dir.AppendASCII("dig_runtime.dll"), &error);
+  if (!native) {
+    return;
+  }
+  lib.start = reinterpret_cast<DigRuntimeStartFn>(
+      base::GetFunctionPointerFromNativeLibrary(native, "dig_runtime_start"));
+  lib.rpc = reinterpret_cast<DigRpcFn>(
+      base::GetFunctionPointerFromNativeLibrary(native, "dig_rpc"));
+  lib.free_fn = reinterpret_cast<DigFreeFn>(
+      base::GetFunctionPointerFromNativeLibrary(native, "dig_free"));
+}
+
+}  // namespace
+
+void StartNativeRuntime() {
+  EnsureLoaded();
+  if (Lib().start) {
+    Lib().start();
+  }
+}
+
+std::string CallDigRpc(const std::string& request_json) {
+  EnsureLoaded();
+  DigRuntimeLib& lib = Lib();
+  if (!lib.rpc || !lib.free_fn) {
+    return std::string();
+  }
+  char* out = lib.rpc(request_json.c_str());
+  if (!out) {
+    return std::string();
+  }
+  std::string result(out);
+  lib.free_fn(out);
+  return result;
+}
+
+}  // namespace dig
