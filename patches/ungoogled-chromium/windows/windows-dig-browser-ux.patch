+// Copyright 2024 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// DIG Browser: the toolbar wallet button. A wallet pouch silhouette with a
+// Chia leaf knocked out of its face (negative space), so the mark reads
+// unmistakably as a CHIA WALLET even as a single monochrome silhouette
+// tinted by the toolbar theme. Drawn on the standard 20dp toolbar canvas
+// (matches navigate_home_chrome_refresh.icon).
+//
+// FILL_RULE_NONZERO with opposing winding: the wallet body is wound
+// clockwise (filled); the leaf and the round clasp hole are wound
+// counter-clockwise so they punch through as holes. Every hole lies fully
+// inside the body, so coverage there is +1 (body) -1 (hole) = 0 → it shows
+// the tinted background through. The leaf's center vein is wound clockwise
+// again so it fills back as a hairline, giving the classic Chia leaf read.
+
+CANVAS_DIMENSIONS, 20,
+FILL_RULE_NONZERO,
+
+// --- Wallet body: a rounded pouch from (2.5,5) to (17.5,16), clockwise. ---
+MOVE_TO, 4.5, 5,
+H_LINE_TO, 15.5,
+CUBIC_TO, 16.6, 5, 17.5, 5.9, 17.5, 7,
+V_LINE_TO, 14,
+CUBIC_TO, 17.5, 15.1, 16.6, 16, 15.5, 16,
+H_LINE_TO, 4.5,
+CUBIC_TO, 3.4, 16, 2.5, 15.1, 2.5, 14,
+V_LINE_TO, 7,
+CUBIC_TO, 2.5, 5.9, 3.4, 5, 4.5, 5,
+CLOSE,
+
+// --- Round clasp hole on the right edge of the pouch, centered at
+// (14.4, 10.5), radius 1.0. Counter-clockwise (top -> left -> bottom ->
+// right -> top) so it subtracts a small circular clasp eyelet. ---
+MOVE_TO, 14.4, 9.5,
+CUBIC_TO, 13.85, 9.5, 13.4, 9.95, 13.4, 10.5,
+CUBIC_TO, 13.4, 11.05, 13.85, 11.5, 14.4, 11.5,
+CUBIC_TO, 14.95, 11.5, 15.4, 11.05, 15.4, 10.5,
+CUBIC_TO, 15.4, 9.95, 14.95, 9.5, 14.4, 9.5,
+CLOSE,
+
+// --- Chia leaf knocked out of the pouch face, centered around (8.3, 10.6).
+// An almond/teardrop: pointed at the top, bellied to the sides, rounded at
+// the base. Counter-clockwise (tip -> down LEFT side -> base -> up RIGHT
+// side -> tip) so it subtracts a leaf-shaped hole. ---
+MOVE_TO, 8.3, 7.6,
+CUBIC_TO, 6.95, 9.0, 6.2, 10.25, 6.2, 11.35,
+CUBIC_TO, 6.2, 12.51, 7.14, 13.45, 8.3, 13.45,
+CUBIC_TO, 9.46, 13.45, 10.4, 12.51, 10.4, 11.35,
+CUBIC_TO, 10.4, 10.25, 9.65, 9.0, 8.3, 7.6,
+CLOSE,
+
+// --- Leaf center vein: a thin sliver down the leaf so the silhouette fills
+// back as a hairline vein (classic Chia look). Stops short of the base. ---
+MOVE_TO, 8.15, 8.8,
+V_LINE_TO, 12.7,
+H_LINE_TO, 8.45,
+V_LINE_TO, 8.8,
+CLOSE
