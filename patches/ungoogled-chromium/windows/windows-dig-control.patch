+// Copyright 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/views/toolbar/dig_control_button.h"
+
+#include "base/functional/bind.h"
+#include "chrome/app/vector_icons/vector_icons.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/navigator/browser_navigator.h"
+#include "chrome/browser/ui/navigator/browser_navigator_params.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/base/page_transition_types.h"
+#include "ui/base/window_open_disposition.h"
+#include "ui/events/event.h"
+#include "ui/events/event_constants.h"
+#include "ui/views/accessibility/view_accessibility.h"
+#include "url/gurl.h"
+
+namespace dig {
+
+DigControlButton::DigControlButton(
+    BrowserWindowInterface* browser_window_interface)
+    : ToolbarButton(base::BindRepeating(&DigControlButton::OpenControlPane,
+                                        base::Unretained(this))),
+      profile_(browser_window_interface->GetProfile()) {
+  // The DIG control mark — three equalizer-style control sliders. A standard
+  // monochrome toolbar vector icon, so SetVectorIcons lets ToolbarButton tint
+  // it with the active toolbar theme color and size it like every other toolbar
+  // button (back, forward, reload, the wallet + shields buttons).
+  SetVectorIcons(kDigControlIcon, kDigControlIcon);
+  // Plain control: this button opens a full page, so (unlike wallet/shields)
+  // there are no dock/pop-out modifiers to surface.
+  SetTooltipText(u"DIG Control Pane\nManage your local DIG node");
+  GetViewAccessibility().SetName(std::u16string(u"DIG Control Pane"));
+  SetTriggerableEventFlags(ui::EF_LEFT_MOUSE_BUTTON |
+                           ui::EF_MIDDLE_MOUSE_BUTTON);
+  SizeToPreferredSize();
+}
+
+DigControlButton::~DigControlButton() = default;
+
+void DigControlButton::OpenControlPane(const ui::Event& event) {
+  if (!profile_) {
+    return;
+  }
+  // FULL-PAGE navigation: open the Control Pane (dig://control) in the active
+  // tab, the way dig://home / dig://about are full pages. NOT a side panel and
+  // NOT a free-floating window — a normal top-level tab navigation. A
+  // middle-click (or ctrl/cmd-click) opens it in a new foreground tab instead,
+  // matching standard toolbar-button behavior.
+  WindowOpenDisposition disposition = WindowOpenDisposition::CURRENT_TAB;
+  if (event.flags() & ui::EF_MIDDLE_MOUSE_BUTTON) {
+    disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  } else if (event.flags() & (ui::EF_CONTROL_DOWN | ui::EF_COMMAND_DOWN)) {
+    disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  }
+  NavigateParams params(profile_.get(), GURL("dig://control"),
+                        ui::PAGE_TRANSITION_AUTO_BOOKMARK);
+  params.disposition = disposition;
+  Navigate(&params);
+}
+
+BEGIN_METADATA(DigControlButton)
+END_METADATA
+
+}  // namespace dig
