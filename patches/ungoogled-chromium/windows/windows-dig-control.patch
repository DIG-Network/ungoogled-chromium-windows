+// Copyright 2026 The DIG Network Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// DIG Browser: the toolbar CONTROL PANE button. Three horizontal "control"
+// sliders (the universal settings/controls mark) — so the button reads as
+// "controls / manage your node" at the toolbar size as a single monochrome
+// silhouette tinted by the active toolbar theme color. Drawn on the standard
+// 20dp toolbar canvas (matches dig_wallet.icon / dig_shield.icon).
+//
+// FILL_RULE_NONZERO. Each control is a horizontal track (a thin rounded bar)
+// with a round knob sitting on it; the three knobs are offset along their tracks
+// (left, right, left) the way an equalizer / settings panel reads. Tracks are
+// drawn as filled rounded rectangles; knobs as filled circles approximated by
+// cubic arcs.
+
+CANVAS_DIMENSIONS, 20,
+FILL_RULE_NONZERO,
+
+// --- Track 1 (top), y=5: a thin rounded bar spanning the canvas width. ---
+ROUND_RECT, 3, 4, 14, 2, 1,
+// Knob on track 1, offset LEFT, centered ~ (7,5), r=2.4 (cubic-arc circle).
+MOVE_TO, 7, 2.6,
+CUBIC_TO, 8.33, 2.6, 9.4, 3.67, 9.4, 5,
+CUBIC_TO, 9.4, 6.33, 8.33, 7.4, 7, 7.4,
+CUBIC_TO, 5.67, 7.4, 4.6, 6.33, 4.6, 5,
+CUBIC_TO, 4.6, 3.67, 5.67, 2.6, 7, 2.6,
+CLOSE,
+
+// --- Track 2 (middle), y=10. ---
+ROUND_RECT, 3, 9, 14, 2, 1,
+// Knob on track 2, offset RIGHT, centered ~ (13,10), r=2.4.
+MOVE_TO, 13, 7.6,
+CUBIC_TO, 14.33, 7.6, 15.4, 8.67, 15.4, 10,
+CUBIC_TO, 15.4, 11.33, 14.33, 12.4, 13, 12.4,
+CUBIC_TO, 11.67, 12.4, 10.6, 11.33, 10.6, 10,
+CUBIC_TO, 10.6, 8.67, 11.67, 7.6, 13, 7.6,
+CLOSE,
+
+// --- Track 3 (bottom), y=15. ---
+ROUND_RECT, 3, 14, 14, 2, 1,
+// Knob on track 3, offset LEFT, centered ~ (7,15), r=2.4.
+MOVE_TO, 7, 12.6,
+CUBIC_TO, 8.33, 12.6, 9.4, 13.67, 9.4, 15,
+CUBIC_TO, 9.4, 16.33, 8.33, 17.4, 7, 17.4,
+CUBIC_TO, 5.67, 17.4, 4.6, 16.33, 4.6, 15,
+CUBIC_TO, 4.6, 13.67, 5.67, 12.6, 7, 12.6,
+CLOSE
