+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_TOOLBAR_DIG_CONTROL_BUTTON_H_
+#define CHROME_BROWSER_UI_VIEWS_TOOLBAR_DIG_CONTROL_BUTTON_H_
+
+#include "base/memory/raw_ptr.h"
+#include "chrome/browser/ui/views/toolbar/toolbar_button.h"
+
+class BrowserWindowInterface;
+class Profile;
+
+namespace ui {
+class Event;
+}  // namespace ui
+
+namespace dig {
+
+// DIG Browser: the CONTROL PANE toolbar button. It carries the DIG control mark
+// and sits next to the wallet + shields buttons. UNLIKE those two (which DOCK
+// their panels in Chromium's Side Panel), pressing this button NAVIGATES THE
+// ACTIVE TAB to the full-page Control Pane at dig://control — a normal top-level
+// navigation, the way dig://home / dig://about are full pages.
+//
+// dig://control is the browser-as-CONTROLLER surface: it serves the My Node
+// controller page (the same embedded page as dig://node), which detects a local
+// dig-node and shows either the management UI (driven by the control.* admin
+// RPCs) or an install landing. The button itself holds no node logic — it just
+// opens the page; the page does the honest detect-and-branch. Reads are never
+// gated on a node (chia:// falls back to rpc.dig.net); only management is.
+class DigControlButton : public ToolbarButton {
+  METADATA_HEADER(DigControlButton, ToolbarButton)
+
+ public:
+  explicit DigControlButton(BrowserWindowInterface* browser_window_interface);
+  DigControlButton(const DigControlButton&) = delete;
+  DigControlButton& operator=(const DigControlButton&) = delete;
+  ~DigControlButton() override;
+
+ private:
+  // Navigates the active tab to the full-page Control Pane (dig://control).
+  void OpenControlPane(const ui::Event& event);
+
+  raw_ptr<Profile> profile_;
+};
+
+}  // namespace dig
+
+#endif  // CHROME_BROWSER_UI_VIEWS_TOOLBAR_DIG_CONTROL_BUTTON_H_
